{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "types": ["node", "jest"]
  },
  "files": [],
  "exclude": [
    "node_modules",
    "**/dist",
    "**/coverage",
    "**/*.test.ts",
    "**/*.test.js",
    "**/__tests__"
  ],
  "references": [
    { "path": "./packages/dsl" },
    { "path": "./packages/runtime" },
    { "path": "./packages/codegen" },
    { "path": "./packages/cli" }
  ]
}
