{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "allowJs": true,
    "moduleResolution": "node",
    "types": ["node", "jest"],
    "composite": true
  },
  "references": [
    { "path": "./packages/dsl" },
    { "path": "./packages/runtime" },
    { "path": "./packages/codegen" },
    { "path": "./packages/cli" }
  ],
  "exclude": ["node_modules", "dist", "**/__tests__/**", "examples"]
}
