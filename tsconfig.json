{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "allowJs": true,
    "moduleResolution": "node",
    "types": ["node", "jest"],
    "paths": {
      "@seans-mfe/contracts": ["./packages/contracts/src/index.ts"],
      "@seans-mfe/contracts/*": ["./packages/contracts/src/*"],
      "@seans-mfe/oclif-base": ["./packages/oclif-base/src/index.ts"],
      "@seans-mfe/oclif-base/*": ["./packages/oclif-base/src/*"],
      "@falese/bff-plugin": ["./packages/bff-plugin/src/index.ts"],
      "@falese/bff-plugin/*": ["./packages/bff-plugin/src/*"],
      "@seans-mfe/framework-react": ["./packages/framework-react/src/index.ts"],
      "@seans-mfe/framework-react/*": ["./packages/framework-react/src/*"],
      "@seans-mfe/framework-angular": ["./packages/framework-angular/src/index.ts"],
      "@seans-mfe/framework-angular/*": ["./packages/framework-angular/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/__tests__/**", "examples"]
}
