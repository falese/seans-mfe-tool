{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "types": ["node", "jest"]
  },
  "files": [],
  "exclude": [
    "node_modules",
    "**/dist/**",
    "**/coverage/**",
    "**/*.test.ts",
    "**/*.test.js",
    "**/__tests__/**",
    "agents/**",
    "examples/**",
    "scripts/**",
    "babel.config.js",
    "jest.config.js",
    "jest.setup.js"
  ],
  "references": [
    { "path": "./packages/dsl" },
    { "path": "./packages/logger" },
    { "path": "./packages/runtime" },
    { "path": "./packages/control" },
    { "path": "./packages/codegen" },
    { "path": "./packages/cli" }
  ]
}
