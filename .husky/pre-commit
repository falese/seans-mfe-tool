#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Run generator tests with 100% coverage requirement ONLY when generator
# sources are staged. Running the focused coverage check unconditionally
# fails commits that touch unrelated files because Jest's coverage gate
# warns "Coverage data for <X> was not found" for non-collected files and
# exits non-zero.
STAGED_GENERATORS=$(git diff --cached --name-only --diff-filter=ACMR -- 'src/codegen/generators/**' 2>/dev/null)
if [ -n "$STAGED_GENERATORS" ]; then
  echo "Running generator tests with 100% coverage requirement..."
  npm test -- src/codegen/generators --coverage --collectCoverageFrom='src/codegen/generators/**/*.js' --passWithNoTests
  if [ $? -ne 0 ]; then
    echo "❌ Generator tests failed or coverage is below 100%"
    echo "TDD mandate (ADR-022): All generators must have 100% test coverage"
    exit 1
  fi
  echo "✅ Generator tests passed with 100% coverage"
else
  echo "Skipping generator coverage gate (no src/codegen/generators/ files staged)"
fi
