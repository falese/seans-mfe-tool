{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*", "tsconfig.json", "package.json"],
      "outputs": ["dist/**"]
    },
    "build:schemas": {
      "dependsOn": ["build"],
      "inputs": ["src/commands/**/*", "scripts/generate-schemas.ts"],
      "outputs": ["schemas/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**/*",
        "packages/*/src/**/*",
        "jest.config.js",
        "jest.setup.js",
        "tsconfig.json"
      ],
      "outputs": ["coverage/**"],
      "cache": true
    },
    "lint": {
      "inputs": ["src/**/*", ".eslintrc*", "eslint.config*"],
      "cache": true
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*", "tsconfig.json"],
      "cache": true
    }
  }
}
