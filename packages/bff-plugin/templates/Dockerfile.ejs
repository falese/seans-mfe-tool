# <%= name %> BFF
# Generated by seans-mfe-tool
# Following ADR-046: GraphQL Mesh with DSL-embedded configuration
# Build context: this MFE's own directory

# Build tools stage — provides seans-mfe-tool CLI and pre-compiled runtime
FROM seans-mfe-tool-cli:latest AS cli-builder

FROM node:20-slim AS builder

WORKDIR /app

# Make the pre-compiled runtime available at a stable path inside the image.
# Using dist/runtime (compiled .js + .d.ts) avoids traversing TypeScript source
# and its transitive deps (zod, dsl/schema, etc.) during ng build / rspack.
COPY --from=cli-builder /seans-mfe-tool /seans-mfe-tool
RUN chmod +x /seans-mfe-tool/bin/run.js && \
    ln -sf /seans-mfe-tool/bin/run.js /usr/local/bin/seans-mfe-tool

# Install dependencies.
# Override @seans-mfe-tool/runtime to the pre-compiled dist package so
# TypeScript sees resolved .d.ts files only — no source traversal.
# Delete from dependencies first (old generated package.json puts it there),
# then set in devDependencies so production --omit=dev install skips it.
COPY package.json ./
RUN npm pkg delete dependencies['@seans-mfe-tool/runtime'] 2>/dev/null || true && \
    npm pkg set devDependencies['@seans-mfe-tool/runtime']='file:/seans-mfe-tool/dist/runtime'
RUN npm install --legacy-peer-deps --no-audit --no-fund

# Copy source files
COPY . .
<% if (includeStatic) { %>
# Build MFE static assets (rspack/webpack + seans-mfe-tool remote:generate).
RUN npm run build
<% } %>
# Build GraphQL Mesh artifacts (.mesh/ directory).
# createBuiltMeshHTTPHandler reads from .mesh/ at server startup — this step
# must run after COPY so specs/ and .meshrc.yaml are present in the build context.
# Runs unconditionally: for standalone BFF this is the only mesh build step;
# for combined MFE+BFF the npm run build above may already run it, but an
# explicit layer here makes the Mesh build visible and guarantees .mesh/ exists.
RUN npx mesh build
# Compile TypeScript server entry point.
RUN npm run build:server

# Production image
FROM node:20-slim AS production

WORKDIR /app

# Use the builder's package.json (npm pkg set moved runtime to devDep path)
# so --omit=dev correctly skips @seans-mfe-tool/runtime resolution entirely.
COPY --from=builder /app/package.json ./
RUN npm install --omit=dev --legacy-peer-deps --no-audit --no-fund
# Copy Mesh artifacts
COPY --from=builder /app/.mesh ./.mesh

# Copy JS plugins dynamically imported by the built Mesh artifacts at runtime.
# .mesh/index.ts references these via import("../mesh-context.js") etc.
COPY --from=builder /app/mesh-context.js ./
<%_ if (meshTransforms.mockSwitch) { _%>
COPY --from=builder /app/mock-switch.js ./
COPY --from=builder /app/mocks.json ./
<%_ } _%>
<% if (includeStatic) { %>
# Copy built static assets
COPY --from=builder /app/dist ./dist
<% } %>
# Copy compiled server
COPY --from=builder /app/server.js ./

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD node -e "require('http').get('http://localhost:<%= port %>/health', (r) => process.exit(r.statusCode === 200 ? 0 : 1))"

# Non-root user for security
RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 meshuser
USER meshuser

ENV PORT=<%= port %>
EXPOSE <%= port %>

CMD ["node", "server.js"]
