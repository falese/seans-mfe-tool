{
  "name": "@seans-mfe/framework-react",
  "version": "0.1.0",
  "description": "React + rspack framework plugin for seans-mfe-tool (ADR-071)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./runtime": {
      "require": "./dist/runtime/index.js",
      "types": "./dist/runtime/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@seans-mfe/contracts": "file:../contracts"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@types/react": "^18.2.0"
  },
  "license": "MIT",
  "peerDependencies": {
    "react": "^18.2.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}