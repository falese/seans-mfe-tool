{
  "name": "@seans-mfe/framework-angular",
  "version": "0.1.0",
  "description": "Angular + webpack framework plugin for seans-mfe-tool (ADR-071)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./runtime": {
      "require": "./dist/runtime/index.js",
      "types": "./dist/runtime/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@seans-mfe/contracts": "file:../contracts"
  },
  "peerDependencies": {
    "@angular/core": "^17.0.0"
  },
  "peerDependenciesMeta": {
    "@angular/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@angular/core": "^17.3.12",
    "typescript": "^5.9.3"
  },
  "license": "MIT"
}
