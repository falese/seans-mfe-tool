/**
 * BFF Server - GraphQL Mesh + Static Assets
 * Generated by seans-mfe-tool
 * Following ADR-046: GraphQL Mesh with DSL-embedded configuration
 * Following ADR-063: TypeScript Mesh Configuration
 */
import express from 'express';
import path from 'path';
import cors from 'cors';
import helmet from 'helmet';
import { getMesh } from '@graphql-mesh/runtime';
import { getMeshOptions } from './mesh.config';
import { createYoga } from 'graphql-yoga';
import type { Request, Response, NextFunction, Express } from 'express';
import crypto from 'crypto';

const app: Express = express();

// Security middleware
app.use(helmet({
  contentSecurityPolicy: {
    directives: {
      defaultSrc: ["'self'"],
      scriptSrc: ["'self'", "'unsafe-inline'", "'unsafe-eval'", "https://unpkg.com"],
      scriptSrcElem: ["'self'", "'unsafe-inline'", "https://unpkg.com"],
      styleSrc: ["'self'", "'unsafe-inline'", "https://unpkg.com"],
      styleSrcElem: ["'self'", "'unsafe-inline'", "https://unpkg.com"],
      imgSrc: ["'self'", 'data:', 'https:'],
      connectSrc: ["'self'", "https://unpkg.com"],
      workerSrc: ["'self'", 'blob:', "https://unpkg.com"],
      childSrc: ["'self'", 'blob:'],
      fontSrc: ["'self'", 'data:', "https://unpkg.com"],
    },
  },
}));

// CORS configuration
app.use(cors({
  origin: process.env.CORS_ORIGIN || '*',
  credentials: true,
}));

// Health check endpoint
app.get('/health', (req: express.Request, res: express.Response) => {
  res.json({ 
    status: 'healthy',
    name: '<%= name %>',
    version: '<%= version %>',
    timestamp: new Date().toISOString()
  });
});

// GraphQL BFF endpoint initialization
// Following REQ-BFF-003: JWT Authentication Forwarding
// Following ADR-063: TypeScript Mesh Configuration with programmatic API
interface MeshContext {
  jwt?: string;
  requestId: string;
  userId?: string;
}

// Initialize Mesh with TypeScript config
async function initializeMesh() {
  const meshOptions = await getMeshOptions();
  const mesh = await getMesh(meshOptions);
  const yoga = createYoga({
    schema: mesh.schema,
    plugins: mesh.plugins,
    context: async (req: any) => {
      const authHeader = req.request?.headers?.get?.('authorization') || req.request?.headers?.authorization;
      return {
        jwt: typeof authHeader === 'string' ? authHeader.replace('Bearer ', '') : undefined,
        requestId: (req.request?.headers?.get?.('x-request-id') || req.request?.headers?.['x-request-id'] || crypto.randomUUID()) as string,
        userId: extractUserIdFromToken(typeof authHeader === 'string' ? authHeader : undefined),
      };
    },
  });
  
  return { mesh, yoga };
}

// Store mesh instance
let yogaServer: Awaited<ReturnType<typeof initializeMesh>>['yoga'];

// Initialize on startup
initializeMesh()
  .then(({ mesh, yoga }) => {
    yogaServer = yoga;
    console.log('✓ GraphQL Mesh initialized');
  })
  .catch((error) => {
    console.error('✗ Failed to initialize Mesh:', error);
    process.exit(1);
  });

// GraphQL endpoint
app.use('/graphql', async (req: Request, res: Response) => {
  if (!yogaServer) {
    return res.status(503).json({ error: 'GraphQL server not ready' });
  }
  
  const response = await yogaServer.handleNodeRequest(req, {});
  res.status(response.status);
  response.headers.forEach((value: string, key: string) => res.setHeader(key, value));
  res.send(await response.text());
});

<% if (includeStatic) { %>
// Static MFE assets
// Following REQ-BFF-004: BFF + Static Assets Same Deployable
app.use(express.static(path.join(__dirname, 'dist')));

// SPA fallback - serve index.html for client-side routing
app.get('*', (req: express.Request, res: express.Response) => {
  res.sendFile(path.join(__dirname, 'dist', 'index.html'));
});
<% } %>

// Error handling
app.use((err: Error, req: express.Request, res: express.Response, next: express.NextFunction) => {
  console.error('Server error:', err);
  res.status(500).json({ 
    error: 'Internal Server Error',
    message: process.env.NODE_ENV === 'development' ? err.message : undefined
  });
});

// Extract user ID from JWT token
function extractUserIdFromToken(authHeader?: string): string | undefined {
  if (!authHeader) return undefined;
  try {
    const token = authHeader.replace('Bearer ', '');
    const payload = JSON.parse(Buffer.from(token.split('.')[1], 'base64').toString());
    return payload.sub || payload.userId;
  } catch {
    return undefined;
  }
}

const port = process.env.PORT || <%= port %>;

app.listen(port, () => {
  console.log(`🚀 <%= name %> BFF server running on port ${port}`);
  console.log(`   GraphQL endpoint: http://localhost:${port}/graphql`);
<% if (includeStatic) { %>
  console.log(`   Static assets: http://localhost:${port}/`);
<% } %>
  console.log(`   Health check: http://localhost:${port}/health`);
  console.log(`   Note: MFE assets served by rspack dev server on port <%= port - 1000 %>`);
});