# MFE Manifest - DSL Contract
# Generated by seans-mfe-tool
# Following ADR-046: GraphQL Mesh with DSL-embedded configuration

name: <%= name %>
version: <%= version %>
type: <%= type %>
language: typescript

<% if (type !== 'bff') { %>
# Module Federation configuration
remoteEntry: http://localhost:<%= port %>/remoteEntry.js

capabilities:
  - name: main
    type: ui
    lifecycle:
      render:
        handler: renderApp
<% } %>

# GraphQL Mesh configuration (REQ-BFF-001)
# This section IS the Mesh config - extracted to .meshrc.yaml by CLI
data:
  # Sources - OpenAPI specs to expose as GraphQL (REQ-BFF-002)
  sources:
<% for (const source of sources) { %>
    - name: <%= source.name %>
      handler:
        openapi:
          source: <%= source.spec %>
          operationHeaders:
            Authorization: 'Bearer {context.jwt}'
            X-Request-ID: '{context.requestId}'
<% if (source.transforms) { %>
      transforms:
<% for (const transform of source.transforms) { %>
        - <%= transform.type %>:
            <%= transform.config %>
<% } %>
<% } %>
<% } %>

<% if (transforms && transforms.length > 0) { %>
  # Global transforms (REQ-BFF-007)
  transforms:
<% for (const transform of transforms) { %>
    - <%= transform.type %>:
        <%= transform.config %>
<% } %>
<% } %>

<% if (plugins && plugins.length > 0) { %>
  # Plugins for production concerns (REQ-BFF-006)
  plugins:
<% for (const plugin of plugins) { %>
    - <%= plugin.name %>:
        <%= plugin.config %>
<% } %>
<% } %>

  # Server configuration
  serve:
    endpoint: /graphql
    playground: <%= playground %>

  # Data lineage (ADR-045)
  generatedFrom:
<% for (const source of sources) { %>
    - openapi: <%= source.spec %>
      service: <%= source.name %>
<% } %>
