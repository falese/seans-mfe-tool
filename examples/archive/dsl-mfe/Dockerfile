# csv-analyzer BFF
# Generated by seans-mfe-tool
# Following ADR-046: GraphQL Mesh with DSL-embedded configuration

FROM node:20-slim AS builder

WORKDIR /app

# Install dependencies
COPY package*.json ./
RUN npm ci

# Copy source files
COPY . .


# Build MFE static assets
RUN npm run build


# Build Mesh artifacts
# Following REQ-BFF-001: DSL Data Section as Mesh Configuration
RUN npm run mesh:build

# Compile TypeScript server
RUN npm run build:server

# Production image
FROM node:20-slim AS production

WORKDIR /app

# Copy package files and install production dependencies only
COPY --from=builder /app/package*.json ./
RUN npm ci --production

# Copy Mesh artifacts
COPY --from=builder /app/.mesh ./.mesh


# Copy built static assets
COPY --from=builder /app/dist ./dist


# Copy compiled server
COPY --from=builder /app/server.js ./

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD node -e "require('http').get('http://localhost:3002/health', (r) => process.exit(r.statusCode === 200 ? 0 : 1))"

# Non-root user for security
RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 meshuser
USER meshuser

EXPOSE 3002

CMD ["node", "server.js"]
