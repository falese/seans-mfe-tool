# abc-kids-multiplication-quiz BFF
# Generated by seans-mfe-tool
# Following ADR-046: GraphQL Mesh with DSL-embedded configuration
# Build context: this MFE's own directory

# Build tools stage — provides seans-mfe-tool CLI and pre-compiled runtime
FROM seans-mfe-tool-cli:latest AS cli-builder

FROM node:20-slim AS builder

WORKDIR /app

# Make the pre-compiled runtime available at a stable path inside the image.
# Using dist/runtime (compiled .js + .d.ts) avoids traversing TypeScript source
# and its transitive deps (zod, dsl/schema, etc.) during ng build / rspack.
COPY --from=cli-builder /seans-mfe-tool /seans-mfe-tool
RUN chmod +x /seans-mfe-tool/bin/run.js && \
    ln -sf /seans-mfe-tool/bin/run.js /usr/local/bin/seans-mfe-tool

# Install dependencies.
# @seans-mfe-tool/runtime is removed from package.json before npm install;
# we then copy it as a real directory (not a symlink) into node_modules.
# A symlink pointing to /seans-mfe-tool/dist/runtime would cause Angular's
# webpack to resolve @angular/* from /seans-mfe-tool instead of /app/node_modules.
COPY package.json ./
RUN npm pkg delete dependencies['@seans-mfe-tool/runtime'] 2>/dev/null || true && \
    npm pkg delete devDependencies['@seans-mfe-tool/runtime'] 2>/dev/null || true
RUN npm install --legacy-peer-deps --no-audit --no-fund

# Copy runtime as a real directory so webpack module resolution stays within /app.
RUN mkdir -p node_modules/@seans-mfe-tool && \
    cp -r /seans-mfe-tool/dist/runtime node_modules/@seans-mfe-tool/runtime

# Copy source files
COPY . .

# Build MFE static assets.
# Angular: seans-mfe-tool remote:generate is included in the build script.
# Mesh build is also included (via shell conditional) when data: is present.
RUN npm run build

# Compile TypeScript server
RUN npm run build:server

# Production image
FROM node:20-slim AS production

WORKDIR /app

COPY --from=builder /app/package.json ./
RUN npm pkg delete dependencies['@seans-mfe-tool/runtime'] 2>/dev/null || true && \
    npm pkg delete devDependencies['@seans-mfe-tool/runtime'] 2>/dev/null || true
RUN npm install --omit=dev --legacy-peer-deps --no-audit --no-fund

# Copy built static assets
COPY --from=builder /app/dist ./dist

# Copy compiled server
COPY --from=builder /app/server.js ./

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD node -e "require('http').get('http://localhost:4003/health', (r) => process.exit(r.statusCode === 200 ? 0 : 1))"

# Non-root user for security
RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 meshuser
USER meshuser

ENV PORT=4003
EXPOSE 4003

CMD ["node", "server.js"]
