{
  "name": "abc-kids-multiplication-quiz",
  "version": "1.0.0",
  "description": "GraphQL BFF + Angular MFE generated by seans-mfe-tool (ADR-046, ADR-069)",
  "scripts": {
    "dev": "concurrently \"ng serve\" \"npm run bff:dev\"",
    "start": "ng serve",
    "build": "ng build && (grep -q '^data:' mfe-manifest.yaml && mesh build || true)",
    "ng": "ng",
    "prebff:dev": "mesh build",
    "bff:dev": "ts-node server.ts",
    "mesh:validate": "mesh validate",
    "test": "jest",
    "build:server": "tsc server.ts --module commonjs --target ES2020 --esModuleInterop true --skipLibCheck true --moduleResolution node --outDir .",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@angular/common": "^17.0.0",
    "@angular/compiler": "^17.0.0",
    "@angular/core": "^17.0.0",
    "@angular/forms": "^17.0.0",
    "@angular/platform-browser": "^17.0.0",
    "@angular/platform-browser-dynamic": "^17.0.0",
    "@graphql-mesh/cli": "^0.100.21",
    "@graphql-mesh/openapi": "^0.109.26",
    "@graphql-mesh/plugin-prometheus": "^2.1.8",
    "@graphql-mesh/plugin-response-cache": "^0.104.20",
    "@graphql-mesh/serve-runtime": "^1.2.4",
    "@graphql-mesh/transform-naming-convention": "0.105.19",
    "@graphql-tools/delegate": "^10.2.4",
    "@graphql-tools/utils": "^9.2.1",
    "@graphql-tools/wrap": "^10.0.5",
    "@seans-mfe-tool/runtime": "file:../../../src/runtime",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "graphql": "^16.8.1",
    "helmet": "^8.1.0",
    "rxjs": "^7.8.0",
    "tslib": "^2.6.0",
    "zone.js": "~0.14.0"
  },
  "devDependencies": {
    "@angular-architects/module-federation": "^17.0.0",
    "@angular-builders/custom-webpack": "^17.0.0",
    "@angular-devkit/build-angular": "^17.0.0",
    "@angular/cli": "^17.0.0",
    "@angular/compiler-cli": "^17.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.10.0",
    "concurrently": "^8.2.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "jest-preset-angular": "^14.0.0",
    "supertest": "^6.3.3",
    "ts-node": "^10.9.1",
    "typescript": "~5.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
