{
  "name": "abc-kids-shell",
  "version": "1.0.0",
  "description": "ABC Kids \u2014 MFE Shell (host)",
  "scripts": {
    "dev": "rspack serve",
    "build": "rspack build",
    "serve": "serve dist -p 3000",
    "test": "jest"
  },
  "dependencies": {
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.14.0",
    "@mui/material": "^5.14.0",
    "@mui/system": "^5.14.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": [
      "@testing-library/jest-dom"
    ],
    "moduleNameMapper": {
      "\\.(css|less|scss|svg|png|jpg)$": "<rootDir>/__mocks__/fileMock.js",
      "^@mui/icons-material/(.*)$": "<rootDir>/__mocks__/iconMock.js"
    },
    "transform": {
      "^.+\\.(ts|tsx)$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    }
  },
  "devDependencies": {
    "@rspack/cli": "^1.7.0",
    "@rspack/core": "^1.7.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@types/jest": "^29.5.14",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "serve": "^14.2.1",
    "ts-jest": "^29.4.11",
    "typescript": "^5.3.3",
    "@seans-mfe-tool/runtime": "file:../../../src/runtime"
  }
}