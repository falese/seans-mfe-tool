{
  "name": "abc-kids-hockey",
  "version": "1.0.0",
  "description": "GraphQL BFF + MFE generated by seans-mfe-tool (ADR-046, ADR-062)",
  "main": "server.ts",
  "scripts": {
    "dev": "concurrently \"rspack serve\" \"npm run bff:dev\"",
    "start": "npm run dev",
    "build": "seans-mfe-tool remote:generate && rspack build && (grep -q '^data:' mfe-manifest.yaml && mesh build || true)",
    "serve": "serve dist -p 3002",
    "prebff:dev": "mesh build",
    "bff:dev": "ts-node server.ts",
    "mesh:validate": "mesh validate",
    "test": "jest",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@graphql-mesh/serve-runtime": "^1.2.4",
    "@graphql-tools/delegate": "^10.2.4",
    "@graphql-tools/utils": "^9.2.1",
    "@graphql-tools/wrap": "^10.0.5",
    "@graphql-mesh/plugin-response-cache": "^0.104.20",
    "@graphql-mesh/plugin-prometheus": "^2.1.8",
    "@graphql-mesh/transform-naming-convention": "^0.105.19",
    "express": "^4.18.2",
    "graphql": "^16.8.1",
    "cors": "^2.8.5",
    "helmet": "^8.1.0",
    "tslib": "^2.6.0",
    "react": "~18.2.0",
    "react-dom": "~18.2.0",
    "@mui/material": "^5.14.0",
    "@mui/system": "^5.14.0",
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0"
  },
  "devDependencies": {
    "@graphql-mesh/cli": "^0.100.21",
    "@graphql-mesh/openapi": "^0.109.26",
    "@seans-mfe-tool/runtime": "^0.1.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "@rspack/cli": "^1.7.0",
    "@rspack/core": "^1.7.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.5.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.1",
    "concurrently": "^8.2.0",
    "serve": "^14.2.1",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": ["@testing-library/jest-dom"],
    "moduleNameMapper": {
      "\\.(css|less|scss|svg|png|jpg)$": "<rootDir>/__mocks__/fileMock.js"
    },
    "transform": {
      "^.+\\.(ts|tsx)$": ["ts-jest", { "tsconfig": "tsconfig.json" }]
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}