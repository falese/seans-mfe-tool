    "@graphql-mesh/openapi": "^0.98.0",
    "@graphql-mesh/runtime": "^0.99.0",
    "@module-federation/enhanced-rspack": "^0.1.1",
    "@mui/material": "^5.14.0",
    "@mui/system": "^5.14.0",
    "concurrently": "^8.2.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "graphql": "^16.8.1",
    "helmet": "^8.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-node": "^10.9.1"
  },
  "devDependencies": {
