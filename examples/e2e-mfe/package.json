{
  "name": "csv-analyzer",
  "version": "1.0.0",
  "scripts": {
    "start": "concurrently \"rspack serve\" \"npm run bff:dev\"",
    "build": "rspack build && npm run bff:build",
    "serve": "serve dist -p 3002",
    "bff:dev": "ts-node server.ts",
    "bff:build": "mesh build"
  },
