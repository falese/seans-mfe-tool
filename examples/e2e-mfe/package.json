    "@graphql-mesh/openapi": "^0.109.24",
    "@graphql-mesh/plugin-response-cache": "^0.2.0",
    "@module-federation/enhanced-rspack": "^0.1.1",
    "@mui/material": "^5.14.0",
    "@mui/system": "^5.14.0",
    "concurrently": "^8.2.0",
