{
  "name": "csv-analyzer",
  "version": "1.0.0",
  "description": "GraphQL BFF + MFE generated by seans-mfe-tool (ADR-046, ADR-062)",
  "main": "server.ts",
  "scripts": {
    "start": "concurrently \"rspack serve\" \"npm run bff:dev\"",
    "build": "seans-mfe-tool remote:generate && rspack build && mesh build",
    "serve": "serve dist -p 3002",
    "bff:dev": "ts-node server.ts",
    "mesh:validate": "mesh validate",
    "test": "jest",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@graphql-mesh/cache-inmemory-lru": "^0.8.19",
    "@graphql-mesh/cache-localforage": "^0.105.19",
    "@graphql-mesh/cli": "^0.100.21",
    "@graphql-mesh/openapi": "^0.109.26",
    "@graphql-mesh/plugin-prometheus": "^2.1.8",
    "@graphql-mesh/plugin-response-cache": "^0.104.20",
    "@graphql-mesh/serve-runtime": "^1.2.4",
    "@graphql-mesh/transform-naming-convention": "^0.105.19",
    "@graphql-tools/delegate": "^10.2.4",
    "@graphql-tools/utils": "^9.2.1",
    "@graphql-tools/wrap": "^10.0.5",
    "@module-federation/enhanced-rspack": "^0.1.1",
    "@mui/material": "^5.14.0",
    "@mui/system": "^5.14.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "graphql": "^16.8.1",
    "helmet": "^8.1.0",
    "react": "~18.2.0",
    "react-dom": "~18.2.0",
    "tslib": "^2.6.0"
  },
  "devDependencies": {
    "@rspack/cli": "^0.5.0",
    "@rspack/core": "^0.5.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "assert": "^2.1.0",
    "buffer": "^6.0.3",
    "concurrently": "^8.2.0",
    "crypto-browserify": "^3.12.0",
    "eslint": "^8.55.0",
    "events": "^3.3.0",
    "https-browserify": "^1.0.0",
    "jest": "^29.7.0",
    "os-browserify": "^0.3.0",
    "path-browserify": "^1.0.1",
    "process": "^0.11.10",
    "serve": "^14.2.1",
    "stream-browserify": "^3.0.0",
    "stream-http": "^3.2.0",
    "supertest": "^6.3.3",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.3",
    "url": "^0.11.3",
    "util": "^0.12.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
