{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "lib": ["ES2022"]
  },
  "include": ["*.ts", "src/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    ".mesh",
    "src/platform",
    "src/**/*.test.ts"
  ]
}
