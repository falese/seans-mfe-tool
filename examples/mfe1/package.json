{
  "name": "mfe1",
  "version": "1.0.0",
  "description": "GraphQL BFF + MFE generated by seans-mfe-tool (ADR-046, ADR-063)",
  "main": "server.ts",
  "type": "commonjs",
  "scripts": {
    "start": "concurrently \"rspack serve\" \"npm run bff:dev\"",
    "build": "rspack build && tsc",
    "serve": "serve dist -p 3002",
    "bff:dev": "ts-node server.ts",
    "bff:build": "tsc",
    "bff:generate": "seans-mfe-tool remote:generate",
    "test": "jest",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@seans-mfe-tool/runtime": "file:../../dist/runtime",
    "@graphql-mesh/runtime": "^0.106.19",
    "@graphql-mesh/utils": "^0.104.18",
    "@graphql-mesh/store": "^0.104.19",
    "@graphql-mesh/merger-stitching": "^0.105.19",
    "@graphql-mesh/openapi": "^0.109.20",
    "@graphql-mesh/graphql": "^0.104.19",
    "@graphql-mesh/json-schema": "^0.109.20",
    "graphql-yoga": "^5.1.1",
    "@graphql-tools/delegate": "^10.2.4",
    "@graphql-tools/utils": "^9.2.1",
    "@graphql-tools/wrap": "^10.0.5",
    "@graphql-mesh/plugin-response-cache": "^0.104.20",
    "@graphql-mesh/plugin-prometheus": "^2.1.8",
    "@graphql-mesh/transform-naming-convention": "0.105.19",
    "@module-federation/enhanced-rspack": "^0.1.1",
    "express": "^4.18.2",
    "graphql": "^16.8.1",
    "cors": "^2.8.5",
    "helmet": "^8.1.0",
    "tslib": "^2.6.0",
    "react": "~18.2.0",
    "react-dom": "~18.2.0",
    "@mui/material": "^5.14.0",
    "@mui/system": "^5.14.0",
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "@rspack/cli": "^0.5.0",
    "@rspack/core": "^0.5.0",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.1",
    "concurrently": "^8.2.0",
    "serve": "^14.2.1",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "path-browserify": "^1.0.1",
    "stream-browserify": "^3.0.0",
    "stream-http": "^3.2.0",
    "https-browserify": "^1.0.0",
    "util": "^0.12.5",
    "url": "^0.11.3",
    "buffer": "^6.0.3",
    "crypto-browserify": "^3.12.0",
    "os-browserify": "^0.3.0",
    "assert": "^2.1.0",
    "process": "^0.11.10",
    "events": "^3.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}