{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "meridian-docking-control": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-builders/custom-webpack:browser",
          "options": {
            "customWebpackConfig": {
              "path": "./webpack.config.js"
            },
            "outputPath": "dist",
            "index": "public/index.html",
            "main": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "polyfills": ["zone.js"],
            "assets": [],
            "styles": [],
            "scripts": []
          },
          "configurations": {
            "production": {
              "optimization": true,
              "outputHashing": "none",
              "namedChunks": false,
              "sourceMap": false
            },
            "development": {
              "optimization": false,
              "outputHashing": "none",
              "namedChunks": true,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "development"
        },
        "serve": {
          "builder": "@angular-builders/custom-webpack:dev-server",
          "options": {
            "port": 5002,
            "host": "0.0.0.0"
          },
          "configurations": {
            "production": {
              "buildTarget": "meridian-docking-control:build:production"
            },
            "development": {
              "buildTarget": "meridian-docking-control:build:development"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}
