{
  "name": "meridian-console",
  "version": "1.0.0",
  "description": "GraphQL BFF + MFE generated by seans-mfe-tool (ADR-012, ADR-027)",
  "main": "server.ts",
  "scripts": {
    "dev": "rspack serve",
    "start": "npm run dev",
    "build": "seans-mfe-tool remote:generate && rspack build && (grep -q '^data:' mfe-manifest.yaml && mesh build || true)",
    "serve": "serve dist -p 5001",
    "test": "jest",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "react": "~18.2.0",
    "react-dom": "~18.2.0",
    "@mui/material": "^5.14.0",
    "@mui/system": "^5.14.0",
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "@rspack/cli": "^1.7.0",
    "@rspack/core": "^1.7.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.5.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.3.3",
    "serve": "^14.2.1",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "@seans-mfe-tool/runtime": "file:../../../dist/runtime"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": [
      "@testing-library/jest-dom"
    ],
    "moduleNameMapper": {
      "\\.(css|less|scss|svg|png|jpg)$": "<rootDir>/__mocks__/fileMock.js"
    },
    "transform": {
      "^.+\\.(ts|tsx)$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    }
  },
  "overrides": {
    "uuid": "^11.1.1",
    "webpack-dev-server": "^5.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}