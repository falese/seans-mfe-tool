{
  "name": "<%= name %>",
  "version": "<%= version %>",
  "description": "GraphQL BFF generated by seans-mfe-tool (ADR-046)",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"npm run mesh:dev\" \"npm run server:dev\"",
    "server:dev": "tsx watch server.ts",
    "build": "npm run mesh:build && npm run build:server",
    "build:server": "tsc server.ts --outDir . --esModuleInterop --module NodeNext --moduleResolution NodeNext",
    "mesh:build": "mesh build",
    "mesh:dev": "mesh dev",
    "mesh:validate": "mesh validate",
    "test": "jest",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@graphql-mesh/cli": "^0.100.0",
    "@graphql-mesh/openapi": "^1.0.0",
    "@graphql-mesh/plugin-response-cache": "^0.104.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "graphql": "^16.8.1",
    "helmet": "^7.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "tsx": "^4.6.2",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
