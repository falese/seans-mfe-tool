{
  "name": "<%= name %>",
  "version": "1.0.0",
  "scripts": {
    "start": "concurrently \"rspack serve\" \"npm run bff:dev\"",
    "build": "rspack build && npm run bff:build",
    "serve": "serve dist -p <%= port %>",
    "bff:dev": "ts-node src/platform/bff/server.ts",
    "bff:build": "mesh build"
  },
  "dependencies": {
    "@mui/material": "<%= muiVersion %>",
    "@mui/system": "<%= muiVersion %>",
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@graphql-mesh/cli": "^0.90.0",
    "@graphql-mesh/openapi": "^0.40.0",
    "@graphql-mesh/plugin-response-cache": "^0.2.0",
    "ts-node": "^10.9.1",
    "concurrently": "^8.2.0"
  },
  "devDependencies": {
    "@rspack/cli": "^0.5.0",
    "@rspack/core": "^0.5.0",
    "path-browserify": "^1.0.1",
    "stream-browserify": "^3.0.0",
    "util": "^0.12.5",
    "url": "^0.11.3",
    "buffer": "^6.0.3",
    "crypto-browserify": "^3.12.0",
    "os-browserify": "^0.3.0",
    "stream-http": "^3.2.0",
    "https-browserify": "^1.0.0",
    "assert": "^2.1.0",
    "process": "^0.11.10",
    "events": "^3.3.0",
    "serve": "^14.2.1"
  }
}
