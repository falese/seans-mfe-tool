{
  "name": "<%= name %>",
  "version": "<%= version %>",
  "description": "GraphQL BFF generated by seans-mfe-tool (ADR-046)",
  "main": "server.ts",
  "type": "module",
  "scripts": {
     "start": "concurrently \"rspack serve\" \"npm run bff:dev\"",
    "dev": "concurrently \"npm run mesh:dev\" \"npm run server:dev\"",
    "server:dev": "tsx watch server.ts",
    "build": "npm run mesh:build && npm run build:server && rspack build",
    "build:server": "tsc server.ts --outDir . --esModuleInterop --module NodeNext --moduleResolution NodeNext",
    "mesh:build": "mesh build",
    "mesh:dev": "mesh dev",
    "mesh:validate": "mesh validate",
    "test": "jest",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@graphql-mesh/cli": "latest",
    "@graphql-mesh/openapi": "latest",
    "@graphql-mesh/plugin-response-cache": "latest",
    "@graphql-mesh/cache-localforage": "latest",
    "@graphql-mesh/merger-stitching": "latest",
    "@graphql-mesh/http": "latest",
    "@graphql-mesh/merger-bare": "latest",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "graphql": "^16.8.1",
    "helmet": "^7.1.0",
    "@module-federation/enhanced-rspack": "^0.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "tsx": "^4.6.2",
    "typescript": "^5.3.2",
     "jest": "^29.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^4.9.5",
    "@rspack/core": "^0.4.0",
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "@rspack/cli": "^0.5.0",
    "@rspack/core": "^0.5.0",
    "path-browserify": "^1.0.1",
    "stream-browserify": "^3.0.0",
    "util": "^0.12.5",
    "url": "^0.11.3",
    "buffer": "^6.0.3",
    "crypto-browserify": "^3.12.0",
    "os-browserify": "^0.3.0",
    "stream-http": "^3.2.0",
    "https-browserify": "^1.0.0",
