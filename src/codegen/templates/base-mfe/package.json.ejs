{
  "name": "<%= name %>",
  "version": "<%= version %>",
  "description": "GraphQL BFF + MFE generated by seans-mfe-tool (ADR-046)",
  "main": "server.ts",
  "scripts": {
    "start": "concurrently \"rspack serve\" \"npm run bff:dev\"",
    "build": "rspack build && npm run bff:build",
    "serve": "serve dist -p <%= port %>",
    "bff:dev": "ts-node server.ts",
    "bff:build": "tsc server.ts --outDir . --esModuleInterop --module NodeNext --moduleResolution NodeNext",
    "mesh:validate": "mesh validate",
    "test": "jest",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@graphql-mesh/cli": "^0.90.0",
    "@graphql-mesh/openapi": "^0.99.0",
    "@graphql-mesh/http": "^0.99.0",
    "@graphql-mesh/runtime": "^0.99.0",
    "@graphql-mesh/cache-localforage": "^0.99.0",
    "@module-federation/enhanced-rspack": "^0.2.0",
    "express": "^4.18.2",
    "express-graphql": "^0.12.0",
    "graphql": "^16.8.1",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "@rspack/cli": "^0.5.0",
    "@rspack/core": "^0.5.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2",
    "path-browserify": "^1.0.1",
    "stream-browserify": "^3.0.0",
    "util": "^0.12.5",
    "url": "^0.11.3",
    "buffer": "^6.0.3",
    "crypto-browserify": "^3.12.0",
    "os-browserify": "^0.3.0",
    "stream-http": "^3.2.0",
    "https-browserify": "^1.0.0",
    "assert": "^2.1.0",
    "process": "^0.11.10",
    "events": "^3.3.0",
    "serve": "^14.2.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}