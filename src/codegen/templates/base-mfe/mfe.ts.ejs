<%/*
  EJS template for RemoteMFE subclass generation
  All template variables are substituted by CLI codegen from DSL manifest

  REQ-RUNTIME-001: Load capability with atomic entry/mount/enable-render
  REQ-RUNTIME-004: Render capability with component awareness
  REQ-RUNTIME-012: Telemetry emission at all checkpoints
*/%>
<%
// Determine which domain capability output types need to be imported from ./types
const baseCapabilityNames = ['load', 'render', 'refresh', 'authorizeAccess', 'health', 'describe', 'schema', 'query', 'emit'];
const domainCapabilities = capabilities.filter(cap => !baseCapabilityNames.includes(cap.method));
const domainTypeImports = domainCapabilities.map(cap => cap.returnTypeBase);
%>
import {
  RemoteMFE,
  type Context,
  type LoadResult,
  type RenderResult,
} from '@seans-mfe-tool/runtime';
<% if (domainTypeImports.length > 0) { %>
import type { <%= domainTypeImports.join(', ') %> } from './types';
<% } %>

/**
 * <%= className %>
 * @description <%= description %>
 * @generated By seans-mfe-tool CLI from DSL manifest
 *
 * @extends RemoteMFE — ALL 9 platform capabilities are INHERITED, not re-implemented:
 *
 *   load()            — Initialize MFE runtime (3-phase: entry → mount → enable-render)
 *                       Fetches remoteEntry.js, initializes Module Federation container,
 *                       wires shared deps (React, MUI), prepares render state.
 *
 *   render()          — Mount React component into a DOM container.
 *                       Selects the correct component, validates props, calls createRoot().
 *
 *   refresh()         — Reload data and re-render without unmounting.
 *                       Checks if state is dirty, fetches fresh data, triggers rerender.
 *
 *   authorizeAccess() — Validate JWT and evaluate user permissions.
 *                       Checks token format, verifies signature, evaluates grants.
 *
 *   health()          — Report MFE health status and dependency liveness.
 *                       Checks all declared dependencies and resource availability.
 *
 *   describe()        — Return the full DSL manifest + runtime metadata.
 *                       Provides uptime, version, and capability inventory.
 *
 *   schema()          — Return the GraphQL SDL for BFF introspection.
 *                       Built from the Mesh configuration in mfe-manifest.yaml.
 *
 *   query()           — Execute a GraphQL query against the BFF.
 *                       Authorizes, parses, executes, caches results.
 *
 *   emit()            — Publish telemetry/events upstream (errors, metrics, traces, logs).
 *                       Validates event format, dispatches to telemetry backend.
 *
 * DOMAIN CAPABILITIES (this MFE's business logic — implement below):
 *<% domainCapabilities.forEach(function(cap) { %>
 *   <%= cap.method %>()<% if (cap.config && cap.config.description) { %> — <%= cap.config.description %><% } %>
 *<% }); %>
 */
export class <%= className %> extends RemoteMFE {
  constructor(manifest: any) {
    super(manifest);
  }

  // ---------------------------------------------------------------------------
  // Platform Capability Overrides (optional — call super() to preserve base behaviour)
  // ---------------------------------------------------------------------------

  /**
   * Override doLoad to add domain-specific initialisation logic.
   *
   * The parent RemoteMFE handles the full 3-phase atomic load:
   *   Phase 1 — Entry:         fetch remoteEntry.js, acquire container
   *   Phase 2 — Mount:         init container, wire shared singleton deps
   *   Phase 3 — Enable-render: mark MFE ready, emit load-completed telemetry
   *
   * Add domain logic AFTER calling super (e.g. validate domain config, seed state).
   */
  protected async doLoad(context: Context): Promise<LoadResult> {
    const result = await super.doLoad(context);
    // TODO: Add domain-specific initialisation here (validate config, seed state, etc.)
    return result;
  }

  /**
   * Override doRender to add domain-specific render logic.
   *
   * The parent RemoteMFE handles:
   *   — Component selection from availableComponents
   *   — Props validation and forwarding
   *   — DOM mounting via React 18 createRoot
   *   — Render telemetry emission
   *
   * Add domain logic AFTER calling super (e.g. analytics, event listeners).
   */
  protected async doRender(context: Context): Promise<RenderResult> {
    const result = await super.doRender(context);
    // TODO: Add domain-specific post-render logic here (analytics, event listeners, etc.)
    return result;
  }

  // ---------------------------------------------------------------------------
  // Domain Capabilities — implement your business logic below
  // ---------------------------------------------------------------------------
<% domainCapabilities.forEach(function(cap) { %>
  /**
   * <%= cap.method %>
   * @description <%= (cap.config && cap.config.description) ? cap.config.description : 'Domain capability — implement logic here.' %>
   * @generated Stub — replace with your domain implementation.
   */
  async <%= cap.method %>(context: Context): Promise<<%= cap.returnTypeBase %>> {
    // TODO: Implement <%= cap.method %> domain logic
    return {} as <%= cap.returnTypeBase %>;
  }
<% }); %>
  // ---------------------------------------------------------------------------
  // Lifecycle Hooks — called by the platform during capability execution
  // ---------------------------------------------------------------------------
<% lifecycleHooks.forEach(function(hook) { %>
  /**
   * <%= hook.name %>
   * @description <%= hook.description || 'Lifecycle hook — implement logic here.' %>
   * @lifecycle <%= hook.phase || 'unknown' %> phase
   * @generated Stub — replace with your implementation.
   */
  protected async <%= hook.name %>(context: Context): Promise<void> {
    // TODO: Implement <%= hook.name %> lifecycle logic
  }
<% }); %>
}
