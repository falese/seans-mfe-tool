<% /*
  EJS template for RemoteMFE subclass generation
  All template variables are substituted by CLI codegen from DSL manifest
  
  REQ-RUNTIME-001: Load capability with atomic entry/mount/enable-render
  REQ-RUNTIME-004: Render capability with component awareness
  REQ-RUNTIME-012: Telemetry emission at all checkpoints
*/ %>
import { RemoteMFE, Context, LoadResult, RenderResult, HealthResult, DescribeResult, SchemaResult, QueryResult, EmitResult } from '@seans-mfe-tool/runtime';

/**
 * <%= className %>
 * @description <%= description %>
 * @generated By seans-mfe-tool CLI from DSL manifest
 * @extends RemoteMFE - Module Federation remote with production-grade load/render handlers
 */
export class <%= className %> extends RemoteMFE {
   constructor(manifest: any) {
      super(manifest);
   }

  /**
   * Override doLoad to add domain-specific load logic
   * Parent RemoteMFE handles:
   * - Entry: Fetch Module Federation remote entry
   * - Mount: Initialize container, wire shared deps
   * - Enable-render: Prepare MFE state for render
   * - Telemetry: Emit metrics at all checkpoints
   */
  protected async doLoad(context: Context): Promise<LoadResult> {
    // Call parent RemoteMFE implementation for Module Federation handling
    const result = await super.doLoad(context);
    
    // Add domain-specific load logic here
    // Example: Initialize domain services, validate domain config, setup state
    
    return result;
  }

  /**
   * Override doRender to add domain-specific render logic
   * Parent RemoteMFE handles:
   * - Component selection from available components
   * - Props validation and passing
   * - DOM mounting with React 18 createRoot
   * - Telemetry: Emit render metrics
   */
  protected async doRender(context: Context): Promise<RenderResult> {
    // Call parent RemoteMFE implementation for component rendering
    const result = await super.doRender(context);
    
    // Add domain-specific render logic here
    // Example: Setup domain event listeners, initialize analytics
    
    return result;
  }

<% 
// Base capabilities already implemented in BaseMFE/RemoteMFE - do not override
const baseCapabilities = ['load', 'render', 'refresh', 'authorizeAccess', 'health', 'describe', 'schema', 'query', 'emit'];
const domainCapabilities = capabilities.filter(cap => !baseCapabilities.includes(cap.method));
%>
<% domainCapabilities.forEach(function(cap) { %>
  /**
  * <%= cap.method %>
  * @description <%= cap.description %>
  * @generated Stub - implement domain logic here.
  */
  protected async <%= cap.method %>(context: Context): Promise<<%- cap.returnTypeBase %>> {
    // TODO: Implement <%= cap.method %> logic
    // WARNING: Stub generated by CLI
    <%- cap.stubBody %>
    return {} as <%- cap.returnTypeBase %>;
  }
<% }); %>

<% lifecycleHooks.forEach(function(hook) { %>
  /**
   * <%= hook.name %>
   * @description <%= hook.description %>
   * @lifecycle <%= hook.phase %>
   * @generated Stub - implement lifecycle logic here.
   */
  protected async <%= hook.name %>(context: Context): Promise<void> {
     // TODO: Implement <%= hook.name %> logic
     // WARNING: Stub generated by CLI
     <%- hook.stubBody %>
  }
<% }); %>

  // ...other capability stubs...
}


/**
 * Type definitions for DSL inputs/outputs
 */
<% 
// Map DSL types to TypeScript types
const typeMapping = {
  'element': 'HTMLElement | null',
  'component': 'React.ComponentType<any>',
  'datetime': 'Date',
  'jwt': 'string',
  'array': 'Array<any>',
  'enum': 'string',
  'file': 'File',
  'object': 'object',
  'string': 'string',
  'number': 'number',
  'boolean': 'boolean'
};

function mapType(dslType) {
  // Handle union types (e.g., "component | object")
  if (dslType.includes('|')) {
    return dslType.split('|').map(t => typeMapping[t.trim()] || t.trim()).join(' | ');
  }
  return typeMapping[dslType] || dslType;
}
%>
<% capabilities.forEach(function(cap) { %>
export interface <%= cap.method %>Inputs {
<% (cap.config.inputs || []).forEach(function(input) { %>
  /** <%= input.description %> */
  <%= input.name %>: <%- mapType(input.type) %>;
<% }); %>
}

export interface <%= cap.method %>Outputs {
<% (cap.config.outputs || []).forEach(function(output) { %>
  /** <%= output.description %> */
  <%= output.name %>: <%- mapType(output.type) %>;
<% }); %>
}
<% }); %>
