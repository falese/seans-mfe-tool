/**
 * Orchestration Service — REST + WebSocket registry for <%= name %>
 *
 * Generated by seans-mfe-tool (ADR-016, ADR-017)
 *
 * Roles:
 *   POST /api/register  — remote MFEs register themselves
 *   GET  /api/discover  — shell runtime fetches current registry
 *   GET  /health        — liveness probe
 *   WS   /              — broadcasts registry updates to shell runtime
 *
 * Pattern adapted from falese/daemon (ComponentDaemon + ComponentRegistry):
 *   registry (this file) publishes update events via WebSocket to
 *   connected shell runtimes, matching the daemon's publish/subscribe
 *   pattern but using REST rather than GraphQL.
 */
import express from 'express';
import http from 'http';
import { WebSocketServer } from 'ws';
import cors from 'cors';
import helmet from 'helmet';
import { RegistryStorage } from './registry/storage';
import { registerHandler } from './api/register';
import { discoverHandler } from './api/discover';
import { createBroadcaster } from './websocket/broadcast';

const PORT = parseInt(process.env.PORT || '<%= orchPort %>', 10);
const CORS_ORIGIN = process.env.CORS_ORIGIN || '*';

const app = express();
const httpServer = http.createServer(app);
const storage = new RegistryStorage();

// ── WebSocket broadcaster (Registry → Shell Runtime) ──────────
// Mirrors the daemon's PubSub.publish() pattern but over plain WS
// so the shell runtime doesn't need a GraphQL client in the browser.
const wsServer = new WebSocketServer({ server: httpServer });
const broadcast = createBroadcaster(wsServer);

// Broadcast registry changes to every connected shell runtime
storage.on('change', (event: { type: string; entry: unknown }) => {
  broadcast({ type: event.type, entry: event.entry, timestamp: new Date().toISOString() });
});

// ── Middleware ─────────────────────────────────────────────────
app.use(express.json());
app.use(cors({ origin: CORS_ORIGIN, credentials: true }));
app.use(helmet({ contentSecurityPolicy: false }));

// ── REST endpoints ─────────────────────────────────────────────
app.post('/api/register', registerHandler(storage, broadcast));
app.get('/api/discover', discoverHandler(storage));

app.get('/health', (_req, res) => {
  res.json({
    status: 'healthy',
    service: '<%= name %>-orchestration',
    registered: storage.size(),
    timestamp: new Date().toISOString(),
  });
});

// ── Error handler ──────────────────────────────────────────────
app.use((err: Error, _req: express.Request, res: express.Response, _next: express.NextFunction) => {
  console.error('[orchestration] Unhandled error:', err.message);
  res.status(500).json({ error: 'Internal Server Error' });
});

// ── Startup ────────────────────────────────────────────────────
httpServer.listen(PORT, '0.0.0.0', () => {
  console.log(`🎛️  Orchestration service running — port ${PORT}`);
  console.log(`   POST /api/register  — MFE registration`);
  console.log(`   GET  /api/discover  — registry discovery`);
  console.log(`   GET  /health        — liveness probe`);
  console.log(`   WS   /              — real-time updates`);
});

export { app, httpServer };
