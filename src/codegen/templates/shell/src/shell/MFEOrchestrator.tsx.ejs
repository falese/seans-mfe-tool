/**
 * MFEOrchestrator — Shell runtime that connects to the daemon and drives
 * Module Federation-based MFE rendering.
 *
 * This is the browser-side equivalent of ComponentDisplaySystem in
 * falese/daemon/component-system/renderer/frontend/src/App.js, extended to:
 *   1. Treat Component.type as a Module Federation remote name
 *   2. Dynamically load the federated MFE instead of rendering a static React component
 *
 * Data flow:
 *   Registry rules fire → Component published (type = MFE name)
 *         ↓  daemon COMPONENT_UPDATE
 *   DaemonBridge delivers Component to this class
 *         ↓  this.mfes Map updated
 *   React state triggers MFERenderer, which loads <mfe-name>/App via Module Federation
 *
 * Generated by seans-mfe-tool (ADR-016)
 */
import React, { useState, useEffect, useCallback } from 'react';
import { DaemonBridge } from './DaemonBridge';
import { MFERenderer } from './MFERenderer';
import type { DaemonMessage } from './DaemonBridge';

export interface ActiveMFE {
  id: string;
  type: string;                            // MFE remote name (e.g. 'csv-analyzer')
  data: Record<string, unknown>;           // props forwarded to the MFE
  remoteEntry: string;                     // URL to fetch remoteEntry.js from
  createdAt: string;
}

interface OrchestratorState {
  mfes: ActiveMFE[];
  connected: boolean;
  error: string | null;
  actions: any[];
}

// Bridge is created per-component-mount (keyed by URL) to honour the daemonUrl prop
const bridgeInstances = new Map<string, DaemonBridge>();

function getBridge(url: string): DaemonBridge {
  if (!bridgeInstances.has(url)) {
    bridgeInstances.set(url, new DaemonBridge(url));
  }
  return bridgeInstances.get(url)!;
}

function useDaemonOrchestrator(daemonUrl: string) {
  const [state, setState] = useState<OrchestratorState>({
    mfes: [],
    connected: false,
    error: null,
    actions: [],
  });

  // Map<id, ActiveMFE> — mutated locally then synced to React state
  const bridge = getBridge(daemonUrl);

  const mfeMap = React.useRef(new Map<string, ActiveMFE>());

  const onAction = useCallback((componentId: string, actionType: string, data?: Record<string, unknown>) => {
    bridge.sendMessage({
      direction: 'ACTION',
      kind:      'ACTION',
      payload:   {
        id:          `action-${Date.now()}`,
        componentId,
        actionType,
        data,
        timestamp:   new Date().toISOString(),
      },
    });
  }, []);

  useEffect(() => {
    // ── COMPONENT direction: daemon is pushing a new/updated MFE to render ──
    const unsubComponent = bridge.onMessage('COMPONENT', (msg: DaemonMessage) => {
      if (msg.kind === 'COMPONENT_UPDATE') {
        const comp = msg.payload as any;
        if (!comp?.id || !comp?.type) return;

        const entry: ActiveMFE = {
          id:          comp.id,
          type:        comp.type,
          data:        comp.data || {},
          // remoteEntry from component.data takes precedence over convention
          remoteEntry: (comp.data?.remoteEntry as string) ||
                       `http://localhost:3002/remoteEntry.js`,
          createdAt:   comp.createdAt || new Date().toISOString(),
        };

        mfeMap.current.set(comp.id, entry);
        setState(prev => ({
          ...prev,
          mfes: Array.from(mfeMap.current.values()),
        }));
      }
    });

    // ── ACTION direction: daemon echoing an action we sent ──────────────────
    const unsubAction = bridge.onMessage('ACTION', (msg: DaemonMessage) => {
      if (msg.kind === 'ACTION_ECHO') {
        setState(prev => ({
          ...prev,
          actions: [msg.payload, ...prev.actions].slice(0, 50),
        }));
      }
    });

    // ── Connect ──────────────────────────────────────────────────────────────
    bridge.connect()
      .then(() => setState(prev => ({ ...prev, connected: true, error: null })))
      .catch(err => setState(prev => ({
        ...prev,
        connected: false,
        error: (err as Error)?.message || 'Connection failed',
      })));

    return () => {
      unsubComponent();
      unsubAction();
      bridge.disconnect();
    };
  }, []);

  return { ...state, onAction };
}

// ========================
// MFEOrchestrator React Component
// ========================

export function MFEOrchestrator({ daemonUrl }: { daemonUrl?: string }) {
  const resolvedUrl = daemonUrl || `ws://${typeof window !== 'undefined' ? window.location.hostname : 'localhost'}:<%= daemonPort %>/graphql`;
  const { mfes, connected, error, onAction, actions } = useDaemonOrchestrator(resolvedUrl);

  return (
    <div style={{ minHeight: '100vh', backgroundColor: '#f9fafb', padding: '2rem' }}>
      <div style={{ maxWidth: '1200px', margin: '0 auto' }}>

        {/* Status bar */}
        <div style={{ marginBottom: '1.5rem', display: 'flex', alignItems: 'center', gap: '0.75rem' }}>
          <div style={{
            width: 12, height: 12, borderRadius: '50%',
            backgroundColor: connected ? '#22c55e' : error ? '#ef4444' : '#f59e0b',
          }} />
          <span style={{ fontSize: 14, color: '#6b7280' }}>
            {connected
              ? `Daemon connected — ${mfes.length} active MFE${mfes.length !== 1 ? 's' : ''}`
              : error ? `Error: ${error}` : 'Connecting to daemon…'}
          </span>
        </div>

        {/* Connection error */}
        {error && (
          <div style={{ backgroundColor: '#fee2e2', border: '1px solid #fca5a5', borderRadius: 8, padding: '1rem', marginBottom: '1rem' }}>
            <strong style={{ color: '#dc2626' }}>Connection Error</strong>
            <p style={{ color: '#b91c1c', marginTop: 4, fontSize: 14 }}>{error}</p>
            <p style={{ color: '#ef4444', marginTop: 4, fontSize: 12 }}>
              Is the daemon running? <code>docker-compose up -d</code>
            </p>
          </div>
        )}

        {/* Active MFEs */}
        {mfes.length === 0 && connected && (
          <p style={{ color: '#9ca3af', fontSize: 14 }}>
            No MFEs active yet. A remote MFE can call{' '}
            <code>updateControlPlaneState({'{ stateKey: "task.complete", stateData: { nextMFE: "my-remote" } }'})</code>{' '}
            to trigger rendering here.
          </p>
        )}

        <div style={{ display: 'flex', flexDirection: 'column', gap: '1.5rem' }}>
          {mfes.map((mfe) => (
            <MFERenderer
              key={mfe.id}
              mfe={mfe}
              onAction={onAction}
            />
          ))}
        </div>

        {/* Recent action echoes */}
        {actions.length > 0 && (
          <details style={{ marginTop: '2rem', backgroundColor: '#fff', borderRadius: 8, padding: '1rem', boxShadow: '0 1px 3px rgba(0,0,0,.1)' }}>
            <summary style={{ cursor: 'pointer', fontWeight: 600, fontSize: 14 }}>
              Recent Actions ({actions.length})
            </summary>
            <ul style={{ marginTop: '0.75rem', listStyle: 'none', padding: 0, display: 'flex', flexDirection: 'column', gap: '0.5rem' }}>
              {actions.map((a: any, i) => (
                <li key={i} style={{ fontSize: 12, fontFamily: 'monospace', backgroundColor: '#f3f4f6', padding: '0.5rem', borderRadius: 4 }}>
                  <strong>{a.actionType}</strong> on {a.componentId}
                </li>
              ))}
            </ul>
          </details>
        )}
      </div>
    </div>
  );
}
