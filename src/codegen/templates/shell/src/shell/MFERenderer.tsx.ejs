/**
 * MFERenderer — Dynamically loads a federated MFE from the daemon's Component envelope.
 *
 * When the daemon delivers a Component with type='csv-analyzer', this component:
 *   1. Injects a <script> tag pointing to remoteEntry.js (if not already loaded)
 *   2. Calls window[remoteName].init(sharedScope) to wire singleton deps
 *   3. Calls window[remoteName].get('./App') to get the React component factory
 *   4. Renders the MFE component inside a <Suspense> boundary
 *
 * Props forwarded:
 *   - All fields from component.data are forwarded as props to the MFE
 *   - onAction callback lets the MFE send actions back to the daemon
 *
 * This approach follows the Module Federation dynamic remote loading pattern
 * documented at: https://webpack.js.org/concepts/module-federation/#dynamic-remote-containers
 *
 * Generated by seans-mfe-tool (ADR-016)
 */
import React, { Suspense, useState, useEffect } from 'react';
import type { ActiveMFE } from './MFEOrchestrator';

declare const __webpack_init_sharing__: (scope: string) => Promise<void>;
declare const __webpack_share_scopes__: Record<string, any>;

interface MFERendererProps {
  mfe: ActiveMFE;
  onAction: (componentId: string, actionType: string, data: Record<string, unknown>) => void;
}

// ── Remote container loader ─────────────────────────────────────────────────
// Injects <script src="remoteEntry.js"> once per URL, then returns the
// Module Federation container at window[remoteName].

const loadedScripts = new Set<string>();

function loadRemoteScript(url: string): Promise<void> {
  if (loadedScripts.has(url)) return Promise.resolve();
  return new Promise((resolve, reject) => {
    const script = document.createElement('script');
    script.src  = url;
    script.type = 'text/javascript';
    script.async = true;
    script.onload  = () => { loadedScripts.add(url); resolve(); };
    script.onerror = () => reject(new Error(`Failed to load remote entry: ${url}`));
    document.head.appendChild(script);
  });
}

async function loadFederatedModule(
  remoteName: string,
  remoteEntryUrl: string,
  exposedModule = './App',
): Promise<any> {
  // Step 1: Inject script tag
  await loadRemoteScript(remoteEntryUrl);

  // Step 2: Init shared scope (singleton deps like React, MUI)
  await __webpack_init_sharing__('default');
  const container = (window as any)[remoteName];
  if (!container) {
    throw new Error(
      `Remote container "${remoteName}" not found at window.${remoteName}. ` +
      `Check that the remoteEntry.js at ${remoteEntryUrl} exports this scope.`,
    );
  }
  await container.init(__webpack_share_scopes__.default);

  // Step 3: Fetch the exposed module factory
  const factory = await container.get(exposedModule);
  return factory();
}

// ── Dynamic component loader with React Suspense ────────────────────────────
// Uses a lazy ref so the module is fetched once per (remoteName + remoteEntryUrl)
// combination, not on every render.

const moduleCache = new Map<string, React.LazyExoticComponent<any>>();

function getLazyMFEComponent(remoteName: string, remoteEntryUrl: string): React.LazyExoticComponent<any> {
  const cacheKey = `${remoteName}@${remoteEntryUrl}`;
  if (!moduleCache.has(cacheKey)) {
    const LazyComponent = React.lazy(async () => {
      const module = await loadFederatedModule(remoteName, remoteEntryUrl);
      // Module Federation exports default or named exports; normalise to { default }
      return 'default' in module ? module : { default: module };
    });
    moduleCache.set(cacheKey, LazyComponent);
  }
  return moduleCache.get(cacheKey)!;
}

// ── MFE error boundary ──────────────────────────────────────────────────────

interface ErrorBoundaryState { error: Error | null }

class MFEErrorBoundary extends React.Component<
  { mfeName: string; children: React.ReactNode },
  ErrorBoundaryState
> {
  constructor(props: any) {
    super(props);
    this.state = { error: null };
  }

  static getDerivedStateFromError(error: Error): ErrorBoundaryState {
    return { error };
  }

  render() {
    if (this.state.error) {
      return (
        <div style={{ padding: '1rem', backgroundColor: '#fee2e2', borderRadius: 8, border: '1px solid #fca5a5' }}>
          <strong style={{ color: '#dc2626' }}>MFE Load Error: {this.props.mfeName}</strong>
          <pre style={{ fontSize: 12, color: '#b91c1c', marginTop: 8, whiteSpace: 'pre-wrap' }}>
            {this.state.error.message}
          </pre>
        </div>
      );
    }
    return this.props.children;
  }
}

// ========================
// MFERenderer Component
// ========================

export function MFERenderer({ mfe, onAction }: MFERendererProps) {
  // Convert MFE name to a valid JS identifier (e.g. 'csv-analyzer' → 'csv_analyzer')
  // This must match the ModuleFederationPlugin `name` field in the remote's rspack.config.js
  const remoteName = mfe.type.replace(/-/g, '_');
  const LazyMFEApp = getLazyMFEComponent(remoteName, mfe.remoteEntry);

  const handleAction = (actionType: string, data: Record<string, unknown> = {}) => {
    onAction(mfe.id, actionType, data);
  };

  return (
    <div style={{ position: 'relative' }}>
      {/* MFE name badge */}
      <div style={{
        position: 'absolute', top: -10, left: 16, zIndex: 1,
        backgroundColor: '#3b82f6', color: '#fff',
        fontSize: 11, fontFamily: 'monospace',
        padding: '2px 8px', borderRadius: 4,
      }}>
        {mfe.type}
      </div>

      <div style={{ border: '1px solid #e5e7eb', borderRadius: 8, overflow: 'hidden' }}>
        <MFEErrorBoundary mfeName={mfe.type}>
          <Suspense
            fallback={
              <div style={{ padding: '2rem', textAlign: 'center', color: '#9ca3af' }}>
                Loading {mfe.type}…
              </div>
            }
          >
            <LazyMFEApp
              {...mfe.data}
              componentId={mfe.id}
              onAction={handleAction}
            />
          </Suspense>
        </MFEErrorBoundary>
      </div>
    </div>
  );
}
