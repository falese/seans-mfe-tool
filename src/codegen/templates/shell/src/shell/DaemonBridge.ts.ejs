/**
 * DaemonBridge — GraphQL-WS client for the shell renderer.
 *
 * Connects to the ShellDaemon's WebSocket endpoint and speaks the
 * graphql-transport-ws protocol. This is the browser-side equivalent of the
 * WebSocket client in falese/daemon/component-system/renderer/frontend/src/App.js.
 *
 * Exposes two methods:
 *   onMessage(direction, callback) — receive COMPONENT or ACTION messages
 *   sendMessage(envelope)          — send an action to the daemon
 *
 * Generated by seans-mfe-tool (ADR-016)
 */

export type MessageDirection = 'COMPONENT' | 'ACTION';

export interface DaemonMessage {
  direction: MessageDirection;
  kind: string;
  payload: unknown;
  metadata: {
    acknowledged: boolean;
    correlationId: string;
    error: string | null;
  };
}

export class DaemonBridge {
  private url: string;
  private ws: WebSocket | null = null;
  private connected = false;
  private reconnectAttempts = 0;
  private readonly maxReconnectAttempts = 10;
  private readonly reconnectBaseMs  = 400;
  private readonly reconnectMaxMs   = 5_000;
  private readonly reconnectFactor  = 1.6;
  private messageHandlers = new Map<MessageDirection, Set<(msg: DaemonMessage) => void>>();

  constructor(url = `ws://${typeof window !== 'undefined' ? window.location.hostname : 'localhost'}:<%= daemonPort %>/graphql`) {
    this.url = url;
  }

  connect(): Promise<void> {
    console.log(`[DaemonBridge] Connecting to daemon at ${this.url}`);
    return new Promise((resolve, reject) => {
      try {
        this.ws = new WebSocket(this.url, 'graphql-transport-ws');

        this.ws.onopen = () => {
          this.connected = true;
          this.reconnectAttempts = 0;
          this.send({ type: 'connection_init' });
          resolve();
        };

        this.ws.onmessage = (event) => {
          let message: any;
          try { message = JSON.parse(event.data as string); }
          catch (e) { console.warn('[DaemonBridge] Failed to parse message:', e); return; }
          this.handleProtocolMessage(message);
        };

        this.ws.onclose = () => {
          this.connected = false;
          this.scheduleReconnect();
        };

        this.ws.onerror = (error) => {
          console.error('[DaemonBridge] WebSocket error', error);
          reject(error);
        };
      } catch (error) {
        console.error('[DaemonBridge] Failed to create WebSocket:', error);
        reject(error);
      }
    });
  }

  private handleProtocolMessage(message: any): void {
    switch (message.type) {
      case 'connection_ack':
        console.log('[DaemonBridge] Connection acknowledged — starting subscription');
        this.startSubscription();
        break;

      case 'next': {
        const envelope = message.payload?.data?.messages as DaemonMessage | undefined;
        if (envelope) {
          const handlers = this.messageHandlers.get(envelope.direction) || new Set();
          handlers.forEach(h => h(envelope));
        }
        break;
      }

      case 'error':
        console.error('[DaemonBridge] GraphQL error from daemon:', message.payload);
        break;

      case 'ping':
        this.send({ type: 'pong' });
        break;
    }
  }

  private startSubscription(): void {
    this.send({
      id: 'renderer-sub',
      type: 'subscribe',
      payload: {
        query: `subscription {
          messages {
            direction
            kind
            payload
            metadata { acknowledged correlationId error }
          }
        }`,
      },
    });
    console.log('[DaemonBridge] Subscription started');
  }

  sendMessage(envelope: Omit<DaemonMessage, 'metadata'> & { metadata?: Partial<DaemonMessage['metadata']> }): void {
    this.send({
      id:   `mutation-${Date.now()}`,
      type: 'subscribe',
      payload: {
        query:     `mutation SendMessage($message: String!) { sendMessage(message: $message) }`,
        variables: { message: JSON.stringify(envelope) },
      },
    });
  }

  onMessage(direction: MessageDirection, callback: (msg: DaemonMessage) => void): () => void {
    if (!this.messageHandlers.has(direction)) {
      this.messageHandlers.set(direction, new Set());
    }
    this.messageHandlers.get(direction)!.add(callback);
    return () => this.messageHandlers.get(direction)?.delete(callback);
  }

  private scheduleReconnect(): void {
    if (this.reconnectAttempts >= this.maxReconnectAttempts) {
      console.error('[DaemonBridge] Max reconnect attempts reached');
      return;
    }
    const delay = Math.min(
      this.reconnectMaxMs,
      this.reconnectBaseMs * Math.pow(this.reconnectFactor, this.reconnectAttempts++),
    );
    console.warn(`[DaemonBridge] Reconnecting in ${delay}ms (attempt ${this.reconnectAttempts}/${this.maxReconnectAttempts})`);
    setTimeout(() => this.connect().catch(() => {}), delay);
  }

  disconnect(): void {
    if (this.ws) this.ws.close();
  }

  private send(message: unknown): void {
    if (this.ws?.readyState === WebSocket.OPEN) {
      this.ws.send(JSON.stringify(message));
    }
  }

  get isConnected(): boolean {
    return this.connected;
  }
}
