/**
 * Shell Runtime — WebSocket client for orchestration service
 *
 * Connects to the orchestration service's WebSocket server and
 * receives push-based registry update events.
 *
 * Pattern adapted from falese/daemon (ComponentDaemon.connectToRegistry):
 *   - Persistent WebSocket connection
 *   - Exponential backoff reconnect (base=400ms, max=5000ms, factor=1.6)
 *   - Typed event dispatch to registry cache
 */
import { registryCache } from './registry-cache';

const RECONNECT_BASE_MS = 400;
const RECONNECT_MAX_MS  = 5000;
const RECONNECT_FACTOR  = 1.6;

let reconnectAttempt = 0;
let stopping = false;
let socket: WebSocket | null = null;

function reconnectDelayMs(attempt: number): number {
  return Math.min(RECONNECT_MAX_MS, RECONNECT_BASE_MS * Math.pow(RECONNECT_FACTOR, attempt));
}

export function connectToOrchestration(wsUrl?: string): void {
  if (stopping) return;

  const url = wsUrl
    || (window as { ORCHESTRATION_WS_URL?: string }).ORCHESTRATION_WS_URL
    || `ws://localhost:<%= orchPort %>`;

  console.log(`[shell-runtime] Connecting to orchestration WS: ${url} (attempt ${reconnectAttempt})`);

  const ws = new WebSocket(url);
  socket = ws;

  ws.onopen = () => {
    console.log('[shell-runtime] Connected to orchestration service');
    reconnectAttempt = 0;
  };

  ws.onmessage = (event: MessageEvent) => {
    try {
      const msg = JSON.parse(event.data as string) as {
        type: 'REGISTERED' | 'UPDATED' | 'DEREGISTERED';
        entry: unknown;
        timestamp: string;
      };
      registryCache.handleEvent(msg);
    } catch {
      console.warn('[shell-runtime] Failed to parse orchestration message');
    }
  };

  ws.onclose = () => {
    if (stopping) return;
    const delay = reconnectDelayMs(reconnectAttempt++);
    console.warn(`[shell-runtime] Orchestration WS closed — retrying in ${delay}ms`);
    setTimeout(() => connectToOrchestration(wsUrl), delay);
  };

  ws.onerror = () => {
    console.error('[shell-runtime] Orchestration WS error');
  };
}

export function disconnectFromOrchestration(): void {
  stopping = true;
  socket?.close();
  socket = null;
}
