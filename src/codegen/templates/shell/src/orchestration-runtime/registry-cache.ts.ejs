/**
 * Shell Runtime — Registry Cache
 *
 * Local in-browser cache of the MFE registry.
 * Hydrated on startup via GET /api/discover and kept current
 * via WebSocket push events from the orchestration service.
 *
 * Consumers call registryCache.getAll() or subscribe to changes
 * via registryCache.on('change', handler).
 */
import { EventEmitter } from 'events';

export interface MFEEntry {
  name: string;
  endpoint: string;
  remoteEntry: string;
  dslEndpoint?: string;
  healthCheck?: string;
  metadata?: Record<string, unknown>;
  registeredAt: string;
  lastSeen: string;
}

class RegistryCache extends EventEmitter {
  private entries = new Map<string, MFEEntry>();

  getAll(): MFEEntry[] {
    return Array.from(this.entries.values());
  }

  get(name: string): MFEEntry | undefined {
    return this.entries.get(name);
  }

  /** Called by the WebSocket client when a push event arrives */
  handleEvent(event: { type: string; entry: unknown }): void {
    if (event.type === 'REGISTERED' || event.type === 'UPDATED') {
      const entry = event.entry as MFEEntry;
      if (entry?.name) {
        this.entries.set(entry.name, entry);
        this.emit('change', { type: event.type, entry });
      }
    } else if (event.type === 'DEREGISTERED') {
      const e = event.entry as { name?: string };
      if (e?.name) {
        this.entries.delete(e.name);
        this.emit('change', { type: event.type, entry: e });
      }
    }
  }

  /** Seed cache from GET /api/discover response */
  hydrate(entries: MFEEntry[]): void {
    entries.forEach((e) => this.entries.set(e.name, e));
    this.emit('hydrated', this.getAll());
  }
}

export const registryCache = new RegistryCache();

/**
 * Bootstrap: fetch current registry snapshot then start WS listener.
 * Call this once in your shell's main entry point.
 */
export async function initOrchestrationRuntime(serviceUrl?: string): Promise<void> {
  const base = serviceUrl || `http://localhost:<%= orchPort %>`;
  try {
    const res = await fetch(`${base}/api/discover`);
    if (res.ok) {
      const data = (await res.json()) as { entries: MFEEntry[] };
      registryCache.hydrate(data.entries ?? []);
    }
  } catch {
    console.warn('[shell-runtime] Could not reach orchestration service — will wait for WS updates');
  }
}
