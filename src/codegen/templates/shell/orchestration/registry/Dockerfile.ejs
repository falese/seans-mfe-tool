# <%= projectName %> — MFERegistry
# Multi-stage: compile TypeScript → run compiled JS in lean production image.
# Generated by seans-mfe-tool (ADR-016, ADR-017)

FROM node:20-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm install --no-audit --no-fund
COPY . .
RUN npx tsc --outDir dist --module commonjs --target es2020 --esModuleInterop --skipLibCheck mfe-registry.ts

FROM node:20-alpine
WORKDIR /app
COPY package*.json ./
RUN npm install --production --no-audit --no-fund
COPY --from=builder /app/dist/mfe-registry.js ./

EXPOSE <%= registryPort %>

ENV NODE_ENV=production

CMD ["node", "mfe-registry.js"]
