/**
 * MFE Registry for <%= projectName %>
 *
 * Component rules engine — follows ComponentRegistry in falese/daemon/simple-registry.js.
 * Extended with MFE-domain rules: when a remote MFE calls updateControlPlaneState(),
 * the rule fires and publishes { type: '<mfe-name>', data: { ...props } }.
 * The shell renderer interprets component.type as a Module Federation remote name
 * and dynamically loads that MFE.
 *
 * Architecture:
 *   Remote MFE calls: updateControlPlaneState({ stateKey: 'task.complete', stateData: { nextMFE: 'report-viewer' } })
 *         ↓  ACTION envelope → daemon → registry handleMessage
 *   Registry rule fires: type='report-viewer', data={ ...stateData }
 *         ↓  componentUpdate subscription → daemon → renderer
 *   Shell renderer: import('report-viewer/App') via Module Federation
 *
 * Rule shape:
 *   name:      unique identifier
 *   condition: (state, action) → boolean
 *   generate:  (state, action) → { type: string, data: object }
 *
 * Generated by seans-mfe-tool (ADR-016, ADR-017)
 */

import { ApolloServer } from 'apollo-server-express';
import { createServer } from 'http';
import { useServer } from 'graphql-ws/use/ws';
import { makeExecutableSchema } from '@graphql-tools/schema';
import { PubSub } from 'graphql-subscriptions';
import express from 'express';
import { v4 as uuidv4 } from 'uuid';
import { WebSocketServer } from 'ws';

// How long a component stays in memory before eviction (prevents unbounded growth)
const COMPONENT_TTL_MS = parseInt(process.env.COMPONENT_TTL_MS || '600000', 10); // 10 min default

// ========================
// MFE REGISTRY
// ========================

class MFERegistry {
  components: Map<string, { component: any; actions: any[]; lastUpdated: string }>;
  rules: Map<string, { condition: (state: any, action: any) => boolean; generate: (state: any, action: any) => { type: string; data: Record<string, unknown> } }>;
  pubsub: PubSub;

  constructor() {
    this.components = new Map();
    this.rules      = new Map();
    this.pubsub     = new PubSub();

    this.setupDefaultRules();
  }

  // ── Default MFE routing rules ───────────────────────────────────────────────
  // These stub rules show the pattern. Replace them with your domain rules.
  //
  // To add a rule programmatically:
  //   registry.addRule('my-rule', {
  //     condition: (state, action) => action.actionType === 'task.complete',
  //     generate:  (state, action) => ({
  //       type: action.data.nextMFE || 'fallback-mfe',
  //       data: { ...action.data, remoteEntry: action.data.remoteEntry }
  //     })
  //   });

  setupDefaultRules(): void {
    // Rule: any MFE signals 'task.complete' → render the MFE named in nextMFE
    this.rules.set('mfe-task-complete', {
      condition: (_state, action) =>
        action.actionType === 'task.complete' &&
        typeof action.data?.nextMFE === 'string',
      generate: (_state, action) => ({
        type: action.data.nextMFE as string,
        data: {
          ...action.data,
          // remoteEntry tells the shell renderer where to fetch the MFE's federation bundle.
          // If not supplied in the action, falls back to REMOTE_MFE_DEFAULT_URL env var.
          remoteEntry: action.data.remoteEntry ||
            (process.env.REMOTE_MFE_DEFAULT_URL ?? 'http://localhost:3002/remoteEntry.js'),
          _ruleEvaluation: {
            rule:      'mfe-task-complete',
            triggeredBy: { actionType: action.actionType, componentId: action.componentId },
            timestamp: new Date().toISOString(),
          },
        },
      }),
    });

    // Rule: any MFE signals 'navigation.requested' → render the target MFE
    this.rules.set('mfe-navigation', {
      condition: (_state, action) =>
        action.actionType === 'navigation.requested' &&
        typeof action.data?.targetMFE === 'string',
      generate: (_state, action) => ({
        type: action.data.targetMFE as string,
        data: {
          ...action.data,
          remoteEntry: action.data.remoteEntry ||
            (process.env.REMOTE_MFE_DEFAULT_URL ?? 'http://localhost:3002/remoteEntry.js'),
          _ruleEvaluation: {
            rule:      'mfe-navigation',
            triggeredBy: { actionType: action.actionType },
            timestamp: new Date().toISOString(),
          },
        },
      }),
    });
  }

  addRule(
    name: string,
    rule: {
      condition: (state: any, action: any) => boolean;
      generate:  (state: any, action: any) => { type: string; data: Record<string, unknown> };
    },
  ): void {
    this.rules.set(name, rule);
    console.log(`[registry] Rule added: ${name}`);
  }

  // ── Message dispatch ────────────────────────────────────────────────────────

  handleMessage(message: any): any {
    if (!message?.direction) {
      console.warn('[registry] Received message without direction — ignoring');
      return null;
    }
    if (message.direction === 'ACTION')    return this.handleAction(message);
    if (message.direction === 'COMPONENT') return this.updateComponentState(message);
    return null;
  }

  // ── Action handling + rule evaluation ──────────────────────────────────────
  // Called when the daemon forwards an action.
  // For each matching rule, a new Component is published on componentUpdate.
  // The Component's type = MFE name; the shell renderer loads it via Module Federation.

  async handleAction(message: any): Promise<boolean | null> {
    const action = message.payload;
    console.log(`[registry] Action received: actionType=${action.actionType} componentId=${action.componentId}`);

    const state = this.components.get(action.componentId);
    if (!state) {
      console.warn(`[registry] No state for component ${action.componentId} — rule evaluation skipped`);
      return null;
    }

    let triggered = false;

    for (const [ruleName, rule] of this.rules) {
      let conditionMet = false;
      try { conditionMet = rule.condition(state, action); }
      catch (e: any) { console.error(`[registry] Rule "${ruleName}" condition threw: ${e.message}`); continue; }

      if (!conditionMet) continue;

      let componentSpec: { type: string; data: Record<string, unknown> } | undefined;
      try { componentSpec = rule.generate(state, action); }
      catch (e: any) { console.error(`[registry] Rule "${ruleName}" generate() threw: ${e.message}`); continue; }

      if (!componentSpec) continue;

      console.log(`[registry] Rule "${ruleName}" fired — publishing component type=${componentSpec.type}`);
      await this.renderComponent(componentSpec);
      triggered = true;
    }

    if (!triggered) {
      console.log(`[registry] No rules matched (actionType=${action.actionType})`);
    }

    return true;
  }

  // ── Component state ─────────────────────────────────────────────────────────

  updateComponentState(message: any): boolean {
    const state = message.payload;
    if (state?.component?.id) {
      this.components.set(state.component.id, state);
      console.log(`[registry] State updated for component ${state.component.id}`);
    }
    return true;
  }

  renderComponent({ type, data }: { type: string; data: Record<string, unknown> }): any {
    const component = {
      id:        uuidv4(),
      type,
      data,
      createdAt: new Date().toISOString(),
    };

    const state = { component, actions: [], lastUpdated: new Date().toISOString() };
    this.components.set(component.id, state);

    // Evict after TTL to prevent unbounded memory growth
    setTimeout(() => this.components.delete(component.id), COMPONENT_TTL_MS);

    console.log(`[registry] Publishing component id=${component.id} type=${component.type}`);
    this.pubsub.publish('COMPONENT_UPDATE', { componentUpdate: component });

    return component;
  }

  getComponents(): any[] {
    return Array.from(this.components.values()).map(s => s.component);
  }

  getComponentStates(): any[] {
    return Array.from(this.components.values());
  }
}

// ========================
// GRAPHQL SCHEMA
// type in Component is intentionally String (not an enum) so the registry
// accepts any MFE name without schema changes.
// ========================

const typeDefs = `
  scalar JSON

  type Query {
    components:      [Component!]!
    componentStates: [ComponentState!]!
  }

  type Mutation {
    renderComponent(type: String!, data: JSON!): Component!
    handleMessage(message: String!): Boolean!
  }

  type Subscription {
    componentUpdate: Component!
  }

  type Component {
    id:        String!
    type:      String!
    data:      JSON!
    createdAt: String!
  }

  type Action {
    id:          String!
    componentId: String!
    actionType:  String!
    data:        JSON!
    timestamp:   String!
  }

  type ComponentState {
    component:   Component!
    actions:     [Action!]!
    lastUpdated: String!
  }
`;

function createResolvers(registry: MFERegistry) {
  return {
    Query: {
      components:      () => registry.getComponents(),
      componentStates: () => registry.getComponentStates(),
    },

    Mutation: {
      renderComponent: (_: any, { type, data }: { type: string; data: any }) => {
        console.log(`[registry] renderComponent type=${type}`);
        return registry.renderComponent({ type, data });
      },
      handleMessage: async (_: any, { message }: { message: string }) => {
        let parsed: any;
        try { parsed = JSON.parse(message); }
        catch { throw new Error('handleMessage: message must be a valid JSON string'); }
        return registry.handleMessage(parsed);
      },
    },

    Subscription: {
      componentUpdate: {
        subscribe: () => registry.pubsub.asyncIterableIterator('COMPONENT_UPDATE'),
      },
    },
  };
}

// ========================
// SERVER STARTUP
// ========================

async function startRegistry(port = <%= registryPort %>) {
  const resolvedPort = parseInt(process.env.PORT || String(port), 10) || port;
  const app          = express();
  const httpServer   = createServer(app);
  const registry     = new MFERegistry();

  app.use(express.json());

  // REST: inject a component directly (useful for testing rule evaluation)
  app.post('/render', (req: any, res: any) => {
    const { type, data } = req.body;
    const component = registry.renderComponent({ type, data });
    res.json({ success: true, component });
  });

  app.get('/', (_req: any, res: any) => res.json({
    service:    '<%= name %>-registry',
    components: registry.getComponents().length,
    rules:      Object.fromEntries(
      Array.from((registry as any).rules.keys()).map(k => [k, 'active']),
    ),
  }));

  app.get('/health', (_req: any, res: any) => res.json({ status: 'healthy', service: '<%= name %>-registry' }));

  const schema = makeExecutableSchema({ typeDefs, resolvers: createResolvers(registry) });

  const server = new ApolloServer({ schema, context: () => ({ registry }) });
  await server.start();
  server.applyMiddleware({ app, path: '/graphql' });

  const wsServer = new WebSocketServer({ server: httpServer, path: '/graphql' });
  useServer({ schema, context: () => ({ registry }) }, wsServer);

  httpServer.listen(resolvedPort, '0.0.0.0', () => {
    console.log(`🚀 Registry listening on http://0.0.0.0:${resolvedPort}`);
    console.log(`   GraphQL:  http://0.0.0.0:${resolvedPort}/graphql`);
    console.log(`   REST:     http://0.0.0.0:${resolvedPort}/render`);
    console.log(`   Rules:    ${(registry as any).rules.size} active`);
  });

  // Publish startup notification so the renderer has something to show immediately
  setTimeout(() => {
    registry.renderComponent({
      type: '<%= name %>-welcome',
      data: {
        message: '<%= projectName %> control plane is ready.',
        remoteEntry: `http://localhost:<%= port %>/remoteEntry.js`,
        _ruleEvaluation: null,
      },
    });
  }, 3_000);

  return registry;
}

if (import.meta.url === `file://${process.argv[1]}`) {
  startRegistry().catch(err => {
    console.error('❌ Registry start failed:', err);
    process.exit(1);
  });
}

export { startRegistry, MFERegistry };
