/**
 * Shell Daemon for <%= projectName %>
 *
 * Concrete Node.js daemon that bridges the ComponentRegistry ↔ MFE Renderer.
 * Follows the DaemonService protocol defined in falese/daemon.
 * See: https://github.com/falese/daemon/blob/main/contracts/DAEMON-CONTRACT.md
 *
 * Architecture:
 *   ComponentRegistry (port <%= registryPort %>) ← persistent GraphQL-WS subscription
 *         ↕
 *   ShellDaemon       (port <%= daemonPort %>)    ← this file
 *         ↕
 *   MFE Renderer (browser) ← GraphQL-WS subscription + sendMessage mutation
 *
 * The daemon is protocol-agnostic: it does not know what MFE names mean.
 * It simply routes Component envelopes (type = MFE name) down to renderers
 * and Action envelopes up to the registry where rules fire.
 *
 * Generated by seans-mfe-tool (ADR-016, ADR-017)
 */

const { parse }         = require('graphql');
const express           = require('express');
const { createServer }  = require('http');
const { makeExecutableSchema } = require('@graphql-tools/schema');
const { PubSub }        = require('graphql-subscriptions');
const { useServer }     = require('graphql-ws/lib/use/ws');
const { WebSocketServer } = require('ws');
const { v4: uuidv4 }    = require('uuid');
const WebSocket         = require('ws');
const GraphQLJSON       = require('graphql-type-json');
const { execute, subscribe } = require('graphql');

// ── Constants ──────────────────────────────────────────────────────────────────
// These match the reconnect constants in falese/daemon/contracts/DaemonService.ts
// exactly. Changing them here changes behaviour for this daemon only.

const WS_SUBPROTOCOL      = 'graphql-transport-ws';
const RECONNECT_BASE_MS   = 400;
const RECONNECT_MAX_MS    = 5_000;
const RECONNECT_FACTOR    = 1.6;
const FORWARD_TIMEOUT_MS  = 4_000;

const MessageDirection = Object.freeze({ COMPONENT: 'COMPONENT', ACTION: 'ACTION' });
const MessageKind = Object.freeze({
  COMPONENT_UPDATE: 'COMPONENT_UPDATE',
  STATE_SNAPSHOT:   'STATE_SNAPSHOT',
  ACTION_ECHO:      'ACTION_ECHO',
});

// ── Structured logger ──────────────────────────────────────────────────────────
// Set LOG_JSON=1 for machine-readable output (Docker log aggregators).

const LOG_JSON = process.env.LOG_JSON === '1';

function logOut(level, fields, msg) {
  const record = { ts: new Date().toISOString(), level, svc: '<%= name %>-daemon', ...fields, msg };
  if (LOG_JSON) { console.log(JSON.stringify(record)); return; }
  const prefix = `${record.ts} [DAEMON] ${level.toUpperCase()} ${record.event || ''}`.trimEnd();
  const extras = Object.entries(record)
    .filter(([k]) => !['ts', 'level', 'svc', 'event', 'msg'].includes(k))
    .map(([k, v]) => `${k}=${v}`).join(' ');
  console.log(`${prefix} — ${msg}${extras ? ' | ' + extras : ''}`);
}

const logger = {
  info:  (fields, msg) => logOut('info',  fields, msg),
  warn:  (fields, msg) => logOut('warn',  fields, msg),
  error: (fields, msg) => logOut('error', fields, msg),
};

// ========================
// SHELL DAEMON
// ========================
// Implements the DaemonService protocol (see DAEMON-CONTRACT.md):
//   - connectToRegistry()       — persistent WS subscription to Registry
//   - onRendererMessage()       — GraphQL resolver body for sendMessage mutation
//   - publish()                 — fan out to renderer subscriptions via PubSub
//   - forwardActionToRegistry() — short-lived WS mutation, fire-and-forget
//   - handleMessage()           — routes ACTION or COMPONENT to the right handler
//   - handleAction()            — 5-step action pipeline (protocol-invariant)

class ShellDaemon {
  constructor() {
    this.componentState          = new Map();  // id → { component, actions, lastUpdated }
    this.pubsub                  = new PubSub();
    this.registrySocket          = null;
    this.registryReconnectAttempt = 0;
    this.stopping                = false;
  }

  // ── Lifecycle ───────────────────────────────────────────────────────────────

  start() {
    this.connectToRegistry();
  }

  async stop() {
    this.stopping = true;  // MUST be first — prevents reconnect timers from firing
    if (this.registrySocket) {
      try { this.registrySocket.close(); } catch (_) { /* already closed */ }
    }
  }

  // ── Registry subscription (persistent) ─────────────────────────────────────
  // Follows DaemonService.connectToRegistry():
  //   - connection_ack → subscribe to componentUpdate
  //   - next frame     → handleComponentFromRegistry()
  //   - close          → exponential backoff reconnect

  connectToRegistry() {
    if (this.stopping) return;

    const url = process.env.REGISTRY_WS_URL ||
      `ws://${process.env.REGISTRY_HOST || 'registry'}:${process.env.REGISTRY_PORT || '<%= registryPort %>'}/graphql`;

    logger.info({ event: 'WS_REGISTRY_CONNECT', url, attempt: this.registryReconnectAttempt },
      'Connecting to registry');

    const ws = new WebSocket(url, WS_SUBPROTOCOL);
    this.registrySocket = ws;

    ws.onopen = () => {
      this.registryReconnectAttempt = 0;  // reset on successful connect
      ws.send(JSON.stringify({ type: 'connection_init' }));
      logger.info({ event: 'WS_REGISTRY_OPEN' }, 'Registry socket open — sending connection_init');
    };

    ws.onmessage = (evt) => {
      let msg;
      try { msg = JSON.parse(evt.data); }
      catch (e) { logger.warn({ event: 'WS_PARSE_ERROR' }, `Failed to parse registry message: ${e.message}`); return; }

      switch (msg.type) {
        case 'connection_ack':
          logger.info({ event: 'WS_REGISTRY_ACK' }, 'Registry acknowledged — subscribing to componentUpdate');
          ws.send(JSON.stringify({
            id: 'registry-sub',
            type: 'subscribe',
            payload: { query: 'subscription { componentUpdate { id type data createdAt } }' },
          }));
          break;

        case 'next': {
          const comp = msg.payload?.data?.componentUpdate;
          if (comp) {
            logger.info({ event: 'COMPONENT_FROM_REGISTRY', compId: comp.id, type: comp.type },
              `Received component from registry (type=${comp.type} — will dispatch to renderers)`);
            this.handleComponentFromRegistry(comp);
          }
          break;
        }

        case 'ping':
          ws.send(JSON.stringify({ type: 'pong' }));
          break;

        case 'error':
          logger.error({ event: 'WS_REGISTRY_ERROR', payload: JSON.stringify(msg.payload || {}) },
            'Registry sent error frame');
          break;
      }
    };

    ws.onclose = () => {
      if (this.stopping) return;
      const delay = Math.min(
        RECONNECT_MAX_MS,
        RECONNECT_BASE_MS * Math.pow(RECONNECT_FACTOR, this.registryReconnectAttempt++),
      );
      logger.warn({ event: 'WS_REGISTRY_CLOSED', retryMs: delay },
        'Registry socket closed — will retry with backoff');
      setTimeout(() => this.connectToRegistry(), delay);
    };

    ws.onerror = (err) => {
      logger.error({ event: 'WS_REGISTRY_ERROR', error: err?.message }, 'Registry socket error');
    };
  }

  // ── Message dispatch ────────────────────────────────────────────────────────
  // Follows DaemonService.handleMessage(): route by direction.

  async handleMessage(message) {
    if (!message || typeof message !== 'object') return null;
    if (message.direction === MessageDirection.ACTION)    return this.handleAction(message);
    if (message.direction === MessageDirection.COMPONENT) return this.handleInboundComponent(message);
    return null;
  }

  // ── 5-step action pipeline ──────────────────────────────────────────────────
  // Protocol invariant — steps MUST execute in this order.
  // See DaemonService.handleAction() in DAEMON-CONTRACT.md for the rationale.
  //
  //   Step 1 — Normalise:  BUTTON_CLICK → CLICK
  //   Step 2 — Record:     append action to per-component action history
  //   Step 3 — Echo:       publish ACTION_ECHO (immediate renderer ack)
  //   Step 4 — Snapshot:   publish STATE_SNAPSHOT (current component state)
  //   Step 5 — Forward:    fire-and-forget mutation to Registry (rules evaluate here)

  async handleAction(envelope) {
    // Step 1: Normalise
    const raw    = envelope.payload;
    const action = raw.actionType === 'BUTTON_CLICK'
      ? { ...raw, actionType: 'CLICK', data: { ...raw.data, originalActionType: 'BUTTON_CLICK' } }
      : raw;

    logger.info({ event: 'ACTION_RECEIVED', actionId: action.id, compId: action.componentId, actionType: action.actionType },
      'Action received from renderer');

    // Step 2: Record
    const state = this.componentState.get(action.componentId);
    if (state) {
      state.actions.push(action);
      state.lastUpdated = new Date().toISOString();
    }

    // Step 3: Echo — immediate acknowledgement to the renderer
    const correlationId = envelope.metadata?.correlationId || action.id;
    const echo = this.buildMessage({
      direction: MessageDirection.ACTION,
      kind:      MessageKind.ACTION_ECHO,
      payload:   action,
      metadata:  { acknowledged: true, correlationId, error: null },
    });
    this.publish(echo);
    logger.info({ event: 'ACTION_ECHO_SENT', actionId: action.id }, 'Action echo sent to renderer');

    // Step 4: Snapshot — full current state to renderer
    if (state) {
      this.publish(this.buildMessage({
        direction: MessageDirection.COMPONENT,
        kind:      MessageKind.STATE_SNAPSHOT,
        payload:   { component: state.component, actions: state.actions, lastUpdated: state.lastUpdated },
        metadata:  { acknowledged: false, correlationId, error: null },
      }));
      logger.info({ event: 'STATE_SNAPSHOT_SENT', compId: action.componentId }, 'State snapshot sent');
    }

    // Step 5: Forward to registry — fire-and-forget
    // Renderer already has echo + snapshot; do NOT await.
    this.forwardActionToRegistry({ ...envelope, payload: action }).catch(err => {
      logger.error({ event: 'ACTION_FORWARD_ERROR', actionId: action.id, error: err?.message },
        'Forward to registry failed');
    });

    return echo;
  }

  // ── Inbound component from renderer (COMPONENT direction) ───────────────────

  handleInboundComponent(envelope) {
    const comp = envelope.payload;
    if (!comp?.id) return null;
    this.storeComponent(comp);
    const msg = this.buildMessage({
      direction: MessageDirection.COMPONENT,
      kind:      MessageKind.COMPONENT_UPDATE,
      payload:   comp,
    });
    this.publish(msg);
    return msg;
  }

  // ── Inbound component from registry subscription ────────────────────────────
  // Called when the registry fires a rule and publishes a componentUpdate.
  // component.type is the MFE name (e.g. 'csv-analyzer', 'report-viewer').

  handleComponentFromRegistry(component) {
    if (!component?.id) return;
    this.storeComponent(component);
    this.publish(this.buildMessage({
      direction: MessageDirection.COMPONENT,
      kind:      MessageKind.COMPONENT_UPDATE,
      payload:   component,
    }));
  }

  // ── Local component state ───────────────────────────────────────────────────
  // Follows DaemonService.storeComponent(): upsert preserving action history.

  storeComponent(component) {
    const existing = this.componentState.get(component.id);
    if (existing) {
      existing.component   = component;
      existing.lastUpdated = new Date().toISOString();
    } else {
      this.componentState.set(component.id, {
        component,
        actions:     [],
        lastUpdated: new Date().toISOString(),
      });
    }
  }

  // ── Forward action to registry ──────────────────────────────────────────────
  // Short-lived connection per action — isolates mutation failures from the
  // persistent subscription socket. Follows DaemonService.forwardActionToRegistry().

  async forwardActionToRegistry(envelope) {
    const url  = process.env.REGISTRY_WS_URL ||
      `ws://${process.env.REGISTRY_HOST || 'registry'}:${process.env.REGISTRY_PORT || '<%= registryPort %>'}/graphql`;
    const opId = `fwd-${uuidv4()}`;
    const ws   = new WebSocket(url, WS_SUBPROTOCOL);

    const timer = setTimeout(() => {
      logger.warn({ event: 'ACTION_FORWARD_TIMEOUT', opId }, 'Forward timed out — closing WS');
      try { ws.close(); } catch (_) { /* already closed */ }
    }, FORWARD_TIMEOUT_MS);

    ws.onopen = () => {
      ws.send(JSON.stringify({ type: 'connection_init' }));
    };

    ws.onmessage = (evt) => {
      let msg;
      try { msg = JSON.parse(evt.data); } catch { return; }

      switch (msg.type) {
        case 'connection_ack':
          ws.send(JSON.stringify({
            id: opId,
            type: 'subscribe',
            payload: {
              query: 'mutation($message: String!) { handleMessage(message: $message) }',
              variables: { message: JSON.stringify(envelope) },
            },
          }));
          break;
        case 'ping':
          ws.send(JSON.stringify({ type: 'pong' }));
          break;
        case 'complete':
          ws.close();
          break;
      }
    };

    ws.onclose = () => {
      clearTimeout(timer);
    };

    ws.onerror = (err) => {
      logger.error({ event: 'ACTION_FORWARD_WS_ERROR', opId, error: err?.message },
        'Forward WS socket error');
    };
  }

  // ── Helpers ─────────────────────────────────────────────────────────────────

  buildMessage({ direction, kind, payload, metadata }) {
    return {
      direction,
      kind,
      payload,
      metadata: metadata || { acknowledged: false, correlationId: uuidv4(), error: null },
    };
  }

  publish(message) {
    this.pubsub.publish('MESSAGES', { messages: message });
  }

  getComponents() {
    return Array.from(this.componentState.values()).map(s => s.component);
  }

  getComponentStates() {
    return Array.from(this.componentState.values());
  }
}

// ========================
// GRAPHQL SCHEMA
// Identical to simple-daemon.js — the protocol does not change between
// the reference implementation and this generated one.
// ========================

const typeDefs = `
  scalar JSON

  enum MessageDirection { COMPONENT ACTION }
  enum MessageKind { COMPONENT_UPDATE STATE_SNAPSHOT ACTION_ECHO }

  type MessageMetadata {
    acknowledged: Boolean!
    correlationId: String
    error: String
  }

  type Message {
    direction: MessageDirection!
    kind:      MessageKind
    payload:   JSON!
    metadata:  MessageMetadata
  }

  type Component {
    id:        String!
    type:      String!
    data:      JSON!
    createdAt: String!
  }

  type Action {
    id:          String!
    componentId: String!
    actionType:  String!
    data:        JSON!
    timestamp:   String!
  }

  type ComponentState {
    component:   Component!
    actions:     [Action!]!
    lastUpdated: String!
  }

  type Query {
    components:      [Component!]!
    componentStates: [ComponentState!]!
  }

  type Mutation {
    sendMessage(message: String!): Boolean!
  }

  type Subscription {
    messages: Message!
  }
`;

function createResolvers(daemon) {
  return {
    JSON: GraphQLJSON,

    Query: {
      components:      () => daemon.getComponents(),
      componentStates: () => daemon.getComponentStates(),
    },

    Mutation: {
      sendMessage: async (_, { message }) => {
        let parsed;
        try { parsed = JSON.parse(message); }
        catch { throw new Error('sendMessage: message must be a valid JSON string'); }
        await daemon.handleMessage(parsed);
        return true;
      },
    },

    Subscription: {
      messages: {
        subscribe: () => daemon.pubsub.asyncIterator('MESSAGES'),
      },
    },
  };
}

// ========================
// SERVER STARTUP
// ========================

async function startDaemon(port = <%= daemonPort %>) {
  const resolvedPort = parseInt(process.env.PORT || String(port), 10) || port;
  const app          = express();
  const httpServer   = createServer(app);
  const daemon       = new ShellDaemon();

  daemon.start();

  const schema = makeExecutableSchema({ typeDefs, resolvers: createResolvers(daemon) });

  app.use(express.json());

  // HTTP POST /graphql — queries and mutations over plain HTTP
  app.post('/graphql', async (req, res) => {
    const { query, variables, operationName } = req.body || {};
    try {
      const result = await execute({ schema, document: parse(query), variableValues: variables, operationName });
      res.json(result);
    } catch (e) {
      res.status(400).json({ errors: [{ message: e.message }] });
    }
  });

  app.get('/', (_req, res) => res.json({
    service:    '<%= name %>-daemon',
    components: daemon.getComponents().length,
    status:     'running',
  }));

  app.get('/health', (_req, res) => res.json({ status: 'healthy', service: '<%= name %>-daemon' }));

  // WebSocket — graphql-transport-ws protocol
  const wsServer = new WebSocketServer({ server: httpServer, path: '/graphql' });
  useServer({
    schema,
    execute,
    subscribe,
    onConnect:    () => logger.info({ event: 'WS_RENDERER_CONNECT' },    'Renderer connected'),
    onError:      (_c, _m, err) => logger.error({ event: 'WS_RENDERER_ERROR',
                    errors: (err || []).map(e => e.message).join('; ') },  'Renderer WS error'),
    onDisconnect: () => logger.info({ event: 'WS_RENDERER_DISCONNECT' }, 'Renderer disconnected'),
  }, wsServer);

  httpServer.listen(resolvedPort, '0.0.0.0', () => {
    logger.info({ event: 'STARTUP', port: resolvedPort }, '<%= name %> daemon listening');
    logger.info({ event: 'REGISTRY_TARGET',
      url: process.env.REGISTRY_WS_URL || `ws://registry:<%= registryPort %>/graphql`,
    }, 'Will connect to registry');
  });

  return daemon;
}

if (require.main === module) {
  const envPort = parseInt(process.env.DAEMON_PORT || process.env.PORT || '', 10);
  const port    = Number.isFinite(envPort) ? envPort : <%= daemonPort %>;
  startDaemon(port).catch(err => {
    console.error('❌ Daemon start failed:', err);
    process.exit(1);
  });
}

module.exports = { startDaemon };
