# <%= projectName %> — Shell (host) app
# Multi-stage build: compile React app with rspack, then serve via nginx.
# Generated by seans-mfe-tool (ADR-016, ADR-017)

FROM node:20-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm install --prefer-offline --no-audit --no-fund
COPY . .
RUN npm run build

FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE <%= port %>
CMD ["nginx", "-g", "daemon off;"]
