# <%= name %> — Docker Compose
# Generated by seans-mfe-tool (ADR-016, ADR-017)
#
# Services:
#   shell              — React host app (Module Federation)
#   orchestration      — MFE registry service (REST + WebSocket)
#   redis              — Optional registry persistence
#
# Usage:
#   docker-compose up -d          # start all services
#   docker-compose logs -f        # tail logs

version: '3.8'

services:
  orchestration:
    build:
      context: ./orchestration-service
      dockerfile: Dockerfile
    ports:
      - "<%= orchPort %>:<%= orchPort %>"
    environment:
      - NODE_ENV=production
      - PORT=<%= orchPort %>
      - CORS_ORIGIN=*
      - REGISTRY_STORAGE=${REGISTRY_STORAGE:-memory}
      - REDIS_URL=redis://redis:6379
    depends_on:
      redis:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "node", "-e", "require('http').get('http://localhost:<%= orchPort %>/health', r => process.exit(r.statusCode === 200 ? 0 : 1))"]
      interval: 30s
      timeout: 3s
      retries: 3
      start_period: 10s
    restart: unless-stopped

  shell:
    build:
      context: .
      dockerfile: Dockerfile
    ports:
      - "<%= port %>:<%= port %>"
    environment:
      - NODE_ENV=production
      - PORT=<%= port %>
      - ORCHESTRATION_SERVICE_URL=http://orchestration:<%= orchPort %>
      - ORCHESTRATION_WS_URL=ws://orchestration:<%= orchPort %>
    depends_on:
      orchestration:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://localhost:<%= port %>"]
      interval: 30s
      timeout: 3s
      retries: 3
      start_period: 15s
    restart: unless-stopped

  redis:
    image: redis:7-alpine
    ports:
      - "6379:6379"
    volumes:
      - redis_data:/data
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 3s
      retries: 3
    restart: unless-stopped

volumes:
  redis_data:

networks:
  default:
    name: <%= name %>-network
