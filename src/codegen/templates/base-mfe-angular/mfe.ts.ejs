<%/*
  EJS template for AngularRemoteMFE subclass generation.
  All template variables are substituted by CLI codegen from DSL manifest.

  Mirrors base-mfe/mfe.ts.ejs but extends AngularRemoteMFE so the generated
  class inherits Angular-flavoured render() (bootstrapApplication) instead of
  the React createRoot path.
*/%>
<%
const baseCapabilityNames = ['load', 'render', 'refresh', 'authorizeAccess', 'health', 'describe', 'schema', 'query', 'emit', 'updateControlPlaneState'];
const domainCapabilities = capabilities.filter(cap => !baseCapabilityNames.includes(cap.method));
const domainTypeImports = domainCapabilities.map(cap => cap.returnTypeBase);
%>
import {
  AngularRemoteMFE,
  type Context,
  type LoadResult,
  type RenderResult,
} from '@seans-mfe-tool/runtime';
<% if (domainTypeImports.length > 0) { %>
import type { <%= domainTypeImports.join(', ') %> } from './types';
<% } %>

/**
 * <%= className %>
 * @description <%= description %>
 * @generated By seans-mfe-tool CLI from DSL manifest
 *
 * @extends AngularRemoteMFE — ALL 10 platform capabilities are INHERITED:
 *   load(), render(), refresh(), authorizeAccess(), health(), describe(),
 *   schema(), query(), emit(), updateControlPlaneState().
 *
 * Render mounts the named standalone component via bootstrapApplication()
 * from @angular/platform-browser; props are applied as @Input() fields on
 * the bootstrapped instance.
 *
 * DOMAIN CAPABILITIES (this MFE's business logic — implement below):
 *<% domainCapabilities.forEach(function(cap) { %>
 *   <%= cap.method %>()<% if (cap.config && cap.config.description) { %> — <%= cap.config.description %><% } %>
 *<% }); %>
 */
export class <%= className %> extends AngularRemoteMFE {
  constructor(manifest: any) {
    super(manifest);
  }

  // ---------------------------------------------------------------------------
  // Platform Capability Overrides (optional — call super() to preserve base behaviour)
  // ---------------------------------------------------------------------------

  protected async doLoad(context: Context): Promise<LoadResult> {
    console.log('[<%= className %>][doLoad] loading remoteEntry=%s', context.inputs?.remoteEntry ?? '<from manifest>');
    const result = await super.doLoad(context);
    if (result.status === 'loaded') {
      console.log('[<%= className %>][doLoad] ready — components=%o duration=%dms', result.availableComponents, result.duration);
    } else {
      console.error('[<%= className %>][doLoad] failed — status=%s error=%s', result.status, result.error?.message);
    }
    return result;
  }

  protected async doRender(context: Context): Promise<RenderResult> {
    console.log('[<%= className %>][doRender] rendering component=%s containerId=%s', context.inputs?.component ?? '<auto>', context.inputs?.containerId ?? '<auto>');
    const result = await super.doRender(context);
    console.log('[<%= className %>][doRender] result=%s duration=%dms', result.status, result.duration);
    return result;
  }

  // ---------------------------------------------------------------------------
  // Domain Capabilities — implement your business logic below
  // ---------------------------------------------------------------------------

  /**
   * loadDomainComponent
   * @description Resolves a domain capability name to its Angular standalone component.
   * Called by AngularRemoteMFE.doRender() — do not call directly.
   */
  protected async loadDomainComponent(name: string): Promise<any> {
    switch (name) {
<% domainCapabilities.forEach(function(cap) { %>
      case '<%= cap.method %>':
        return import('../../features/<%= cap.method %>/<%= cap.method %>.component').then(
          (m: any) => m['<%= cap.method %>Component'] ?? m.default
        );
<% }); %>
      default:
        throw new Error(`[<%= className %>] loadDomainComponent: unknown component "${name}"`);
    }
  }
<% domainCapabilities.forEach(function(cap) { %>
  /**
   * <%= cap.method %>
   * @description <%= (cap.config && cap.config.description) ? cap.config.description : 'Domain capability — implement logic here.' %>
   * @generated Stub — replace with your domain implementation.
   */
  async <%= cap.method %>(context: Context): Promise<<%= cap.returnTypeBase %>> {
    // TODO: Implement <%= cap.method %> domain logic
    return {} as <%= cap.returnTypeBase %>;
  }
<% }); %>
  // ---------------------------------------------------------------------------
  // Lifecycle Hooks — called by the platform during capability execution
  // ---------------------------------------------------------------------------
<% lifecycleHooks.forEach(function(hook) { %>
  /**
   * <%= hook.name %>
   * @description <%= hook.description || 'Lifecycle hook — implement logic here.' %>
   * @lifecycle <%= hook.phase || 'unknown' %> phase
   */
  protected async <%= hook.name %>(context: Context): Promise<void> {
    console.log('[<%= className %>][<%= hook.phase %>][<%= hook.name %>]', {
      requestId: context.requestId,
      capability: context.capability,
      phase: context.phase,
    });
  }
<% }); %>
}
