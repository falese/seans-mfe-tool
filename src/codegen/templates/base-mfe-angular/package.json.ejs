{
  "name": "<%= name %>",
  "version": "<%= version %>",
  "description": "GraphQL BFF + Angular MFE generated by seans-mfe-tool (ADR-046, ADR-062)",
  "main": "server.ts",
  "scripts": {
    "dev": "concurrently \"webpack serve --mode development\" \"npm run bff:dev\"",
    "start": "npm run dev",
    "build": "seans-mfe-tool remote:generate && webpack --mode production && mesh build",
    "serve": "serve dist -p <%= port %>",
    "bff:dev": "ts-node server.ts",
    "mesh:validate": "mesh validate",
    "test": "jest",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@seans-mfe-tool/runtime": "*",
    "@graphql-mesh/cli": "<%= dependencyVersions.graphqlMesh.cli %>",
    "@graphql-mesh/openapi": "<%= dependencyVersions.graphqlMesh.openapi %>",
    "@graphql-mesh/serve-runtime": "<%= dependencyVersions.graphqlMesh.serveRuntime %>",
    "@graphql-tools/delegate": "<%= dependencyVersions.graphqlTools.delegate %>",
    "@graphql-tools/utils": "<%= dependencyVersions.graphqlTools.utils %>",
    "@graphql-tools/wrap": "<%= dependencyVersions.graphqlTools.wrap %>",
<%_ if (neededPlugins.includes('responseCache')) { _%>
    "@graphql-mesh/plugin-response-cache": "<%= dependencyVersions.meshPlugins.responseCache %>",
<%_ } _%>
<%_ if (neededPlugins.includes('prometheus')) { _%>
    "@graphql-mesh/plugin-prometheus": "<%= dependencyVersions.meshPlugins.prometheus %>",
<%_ } _%>
<%_ if (neededPlugins.includes('opentelemetry')) { _%>
    "@graphql-mesh/plugin-opentelemetry": "<%= dependencyVersions.meshPlugins.opentelemetry %>",
<%_ } _%>
<%_ if (neededTransforms.includes('namingConvention')) { _%>
    "@graphql-mesh/transform-naming-convention": "<%= dependencyVersions.meshTransforms.namingConvention %>",
<%_ } _%>
<%_ if (neededTransforms.includes('rateLimit')) { _%>
    "@graphql-mesh/transform-rate-limit": "<%= dependencyVersions.meshTransforms.rateLimit %>",
<%_ } _%>
<%_ if (neededTransforms.includes('filterSchema')) { _%>
    "@graphql-mesh/transform-filter-schema": "<%= dependencyVersions.meshTransforms.filterSchema %>",
<%_ } _%>
<%_ if (neededTransforms.includes('resolversComposition')) { _%>
    "@graphql-mesh/transform-resolvers-composition": "<%= dependencyVersions.meshTransforms.resolversComposition %>",
<%_ } _%>
    "express": "<%= dependencyVersions.core.express %>",
    "graphql": "<%= dependencyVersions.core.graphql %>",
    "cors": "<%= dependencyVersions.core.cors %>",
    "helmet": "<%= dependencyVersions.core.helmet %>",
    "tslib": "<%= dependencyVersions.core.tslib %>",
    "@angular/core": "<%= dependencyVersions.angular.core %>",
    "@angular/common": "<%= dependencyVersions.angular.common %>",
    "@angular/compiler": "<%= dependencyVersions.angular.compiler %>",
    "@angular/platform-browser": "<%= dependencyVersions.angular.platformBrowser %>",
    "rxjs": "<%= dependencyVersions.angular.rxjs %>",
    "zone.js": "<%= dependencyVersions.angular.zoneJs %>"
  },
  "devDependencies": {
    "@angular/compiler-cli": "<%= dependencyVersions.angular.compilerCli %>",
    "@ngtools/webpack": "<%= dependencyVersions.webpackTools.ngtoolsWebpack %>",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "webpack": "<%= dependencyVersions.webpackTools.webpack %>",
    "webpack-cli": "<%= dependencyVersions.webpackTools.webpackCli %>",
    "webpack-dev-server": "<%= dependencyVersions.webpackTools.webpackDevServer %>",
    "html-webpack-plugin": "<%= dependencyVersions.webpackTools.htmlWebpackPlugin %>",
    "typescript": "~5.2.0",
    "ts-node": "<%= dependencyVersions.buildTools.tsNode %>",
    "concurrently": "<%= dependencyVersions.buildTools.concurrently %>",
    "serve": "<%= dependencyVersions.buildTools.serve %>",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "jest-preset-angular": "<%= dependencyVersions.webpackTools.jestPresetAngular %>",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
