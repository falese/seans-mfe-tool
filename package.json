{
  "name": "seans-mfe-tool",
  "version": "1.0.0",
  "main": "bin/seans-mfe-tool.js",
  "scripts": {
    "build": "tsc && node scripts/copy-runtime-files.js",
    "build:watch": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --reporters='default' --reporters='jest-junit'",
    "lint": "eslint src/**/*.{js,ts}",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json}\"",
    "dev": "node bin/seans-mfe-tool.js",
    "clean:test-workspaces": "node scripts/clean-test-workspaces.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "module-federation",
    "react",
    "mui",
    "rspack",
    "microfrontend",
    "cli"
  ],
  "author": "Sean",
  "license": "MIT",
  "description": "CLI tool for scaffolding Module Federation applications with React and MUI",
  "bin": {
    "seans-mfe-tool": "./bin/seans-mfe-tool.js"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^10.1.0",
    "@babel/core": "^7.22.1",
    "@babel/generator": "^7.22.1",
    "@babel/parser": "^7.23.0",
    "@babel/traverse": "^7.23.0",
    "@babel/types": "^7.22.1",
    "@mui/icons-material": "^7.3.6",
    "@rspack/core": "^1.1.3",
    "@rspack/dev-server": "^1.0.9",
    "@rspack/plugin-react-refresh": "0.5.7",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "diff": "^5.1.0",
    "ejs": "^3.1.10",
    "fs-extra": "^11.2.0",
    "inquirer": "^12.0.1",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "react-refresh": "^0.14.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/plugin-transform-runtime": "^7.25.9",
    "@babel/preset-env": "^7.26.0",
    "@types/ejs": "^3.1.5",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.10.1",
    "babel-jest": "^29.7.0",
    "eslint": "^9.14.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-environment-node": "^29.7.0",
    "nodemon": "^3.1.7",
    "prettier": "^3.3.3",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
