{
  "name": "seans-mfe-tool",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prebuild": "npm install",
    "build": "npm run build:logger && npm run build:dsl && npm run build:runtime && npm run build:control && npm run build:codegen && npm run build:cli && npm run build:daemon",
    "build:cli": "npm run build --workspace=@seans-mfe-tool/cli",
    "build:runtime": "npm run build --workspace=@seans-mfe-tool/runtime",
    "build:control": "npm run build --workspace=@seans-mfe-tool/control",
    "build:dsl": "npm run build --workspace=@seans-mfe-tool/dsl",
    "build:logger": "npm run build --workspace=@seans-mfe-tool/logger",
    "build:codegen": "npm run build --workspace=@seans-mfe-tool/codegen",
    "build:daemon": "npm run build --workspace=@seans-mfe-tool/daemon",
    "build:daemon:dev": "npm run build:dev --workspace=@seans-mfe-tool/daemon",
    "build:watch": "tsc --watch",
    "daemon": "npm run dev --workspace=@seans-mfe-tool/daemon",
    "daemon:dev": "npm run dev --workspace=@seans-mfe-tool/daemon",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --reporters='default' --reporters='jest-junit'",
    "test:daemon": "bash packages/daemon/test.sh",
    "lint": "eslint packages/*/src/**/*.{js,ts}",
    "format": "prettier --write \"packages/**/src/**/*.{js,jsx,ts,tsx,json}\"",
    "dev": "node packages/cli/bin/seans-mfe-tool.js",
    "clean": "rm -rf packages/*/dist packages/*/tsconfig.tsbuildinfo packages/daemon/target",
    "clean:test-workspaces": "node scripts/clean-test-workspaces.js",
    "typecheck": "tsc --build --force tsconfig.build.json"
  },
  "keywords": [
    "module-federation",
    "react",
    "mui",
    "rspack",
    "microfrontend",
    "cli"
  ],
  "author": "Sean",
  "license": "MIT",
  "description": "CLI tool for scaffolding Module Federation applications with React and MUI",
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/plugin-transform-runtime": "^7.25.9",
    "@babel/preset-env": "^7.26.0",
    "@types/ejs": "^3.1.5",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.10.1",
    "babel-jest": "^29.7.0",
    "eslint": "^9.14.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-environment-node": "^29.7.0",
    "nodemon": "^3.1.7",
    "prettier": "^3.3.3",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
