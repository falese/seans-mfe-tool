{
  "name": "seans-mfe-tool",
  "version": "1.0.0",
  "packageManager": "npm@10.8.1",
  "main": "bin/run.js",
  "workspaces": [
    "packages/*",
    "src/runtime"
  ],
  "scripts": {
    "build:packages": "tsc -b packages/contracts packages/oclif-base packages/bff-plugin packages/framework-react packages/framework-angular",
    "build": "npm run build:packages && tsc -p tsconfig.build.json && node scripts/copy-runtime-files.js && node scripts/remove-dist-shims.js && npx oclif manifest && npm run build:schemas",
    "build:schemas": "ts-node scripts/generate-schemas.ts",
    "build:schemas:check": "ts-node scripts/generate-schemas.ts --check",
    "build:watch": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --reporters='default' --reporters='jest-junit'",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:perf": "node tests/performance/run-all.js",
    "lint": "eslint src/**/*.{js,ts}",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json}\"",
    "dev": "bun bin/dev.ts",
    "clean:test-workspaces": "node scripts/clean-test-workspaces.js",
    "typecheck": "tsc --noEmit",
    "test:mesh-deps": "node scripts/test-mesh-dependencies.js",
    "docker:build:cli": "docker build -f Dockerfile.cli -t seans-mfe-tool-cli:latest .",
    "docker:build:examples": "docker compose -f examples/abc-kids/docker-compose.yaml build"
  },
  "keywords": [
    "module-federation",
    "react",
    "mui",
    "rspack",
    "microfrontend",
    "cli"
  ],
  "author": "Sean",
  "license": "MIT",
  "description": "CLI tool for scaffolding Module Federation applications with React and MUI",
  "bin": {
    "seans-mfe-tool": "./bin/run.js"
  },
  "files": [
    "bin/run.js",
    "dist",
    "oclif.manifest.json",
    "schemas"
  ],
  "oclif": {
    "bin": "seans-mfe-tool",
    "dirname": "seans-mfe-tool",
    "commands": {
      "strategy": "pattern",
      "target": "./dist/commands",
      "globPatterns": [
        "**/*.+(js|cjs|mjs)",
        "!**/*.+(test.js|spec.js)",
        "!**/_*.+(js|cjs|mjs)"
      ]
    },
    "scope": "@seans-mfe",
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-plugins"
    ],
    "topics": {
      "daemon": {
        "description": "Control-plane daemon commands (requires @falese/daemon-plugin)"
      },
      "coder": {
        "description": "AI-assisted coding commands (requires @falese/coder-plugin)"
      }
    },
    "hooks": {
      "init": "./dist/hooks/init",
      "prerun": "./dist/hooks/prerun",
      "postrun": "./dist/hooks/postrun",
      "command_not_found": "./dist/hooks/command-not-found"
    }
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^10.1.0",
    "@babel/generator": "^7.22.1",
    "@babel/parser": "^7.23.0",
    "@babel/traverse": "^7.23.0",
    "@babel/types": "^7.22.1",
    "@falese/bff-plugin": "file:packages/bff-plugin",
    "@oclif/core": "^4.10.5",
    "@oclif/plugin-help": "^6.2.44",
    "@oclif/plugin-plugins": "^5.4.61",
    "@seans-mfe/contracts": "file:packages/contracts",
    "@seans-mfe/oclif-base": "file:packages/oclif-base",
    "chalk": "^4.1.2",
    "diff": "^5.1.0",
    "ejs": "^3.1.10",
    "fs-extra": "^11.2.0",
    "inquirer": "^12.0.1",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/plugin-transform-runtime": "^7.25.9",
    "@babel/preset-env": "^7.26.0",
    "@octokit/rest": "^22.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/ejs": "^3.1.5",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "ajv": "^8.17.1",
    "babel-jest": "^29.7.0",
    "eslint": "^9.14.0",
    "http-server": "^14.1.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "jest-environment-node": "^29.7.0",
    "nodemon": "^3.1.7",
    "oclif": "^4.23.0",
    "prettier": "^3.3.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
