{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seans-mfe.dev/schemas/bff:validate.json",
  "title": "bff:validate",
  "description": "Input/output contract for seans-mfe-tool bff:validate",
  "input": {
    "type": "object",
    "properties": {
      "manifest": {
        "type": "string",
        "default": "mfe-manifest.yaml"
      }
    }
  },
  "output": {
    "type": "object",
    "required": [
      "valid",
      "issues"
    ],
    "properties": {
      "valid": {
        "type": "boolean"
      },
      "issues": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "severity",
            "message"
          ],
          "properties": {
            "severity": {
              "type": "string",
              "enum": [
                "error",
                "warning"
              ]
            },
            "message": {
              "type": "string"
            },
            "path": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      }
    },
    "additionalProperties": false
  },
  "errorCodes": [
    0,
    2,
    64,
    65,
    66,
    69,
    70,
    77,
    124
  ]
}
