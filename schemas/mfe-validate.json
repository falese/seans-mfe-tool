{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seans-mfe.dev/schemas/mfe:validate.json",
  "title": "mfe:validate",
  "description": "Input/output contract for seans-mfe-tool mfe:validate",
  "input": {
    "type": "object",
    "properties": {
      "dir": {
        "type": "string",
        "description": "MFE directory to validate (default: cwd)"
      },
      "typecheck": {
        "type": "boolean",
        "default": false,
        "description": "Also run `tsc --noEmit`"
      }
    }
  },
  "output": {
    "type": "object",
    "required": [
      "mfe",
      "framework",
      "ok",
      "checked",
      "issues"
    ],
    "properties": {
      "mfe": {
        "type": "string"
      },
      "framework": {
        "type": "string"
      },
      "ok": {
        "type": "boolean"
      },
      "checked": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "issues": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "rule",
            "message"
          ],
          "properties": {
            "rule": {
              "type": "string"
            },
            "message": {
              "type": "string"
            },
            "package": {
              "type": "string"
            },
            "expected": {
              "type": "string"
            },
            "actual": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      },
      "typecheck": {
        "type": "object",
        "required": [
          "ran",
          "ok"
        ],
        "properties": {
          "ran": {
            "type": "boolean"
          },
          "ok": {
            "type": "boolean"
          },
          "output": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "additionalProperties": false
  },
  "errorCodes": [
    0,
    2,
    64,
    65,
    66,
    69,
    70,
    77,
    124
  ]
}
