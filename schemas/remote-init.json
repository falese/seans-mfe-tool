{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seans-mfe.dev/schemas/remote:init.json",
  "title": "remote:init",
  "description": "Input/output contract for seans-mfe-tool remote:init",
  "input": {
    "type": "object",
    "required": [
      "name"
    ],
    "properties": {
      "name": {
        "type": "string"
      },
      "port": {
        "type": "string",
        "default": "3001"
      },
      "template": {
        "type": "string"
      },
      "skip-install": {
        "type": "boolean",
        "default": false
      },
      "force": {
        "type": "boolean",
        "default": false
      },
      "dry-run": {
        "type": "boolean",
        "default": false
      }
    }
  },
  "output": {
    "type": "object",
    "required": [
      "name",
      "port",
      "targetDir",
      "generatedFiles",
      "dryRun"
    ],
    "properties": {
      "name": {
        "type": "string"
      },
      "port": {
        "type": "number"
      },
      "targetDir": {
        "type": "string"
      },
      "generatedFiles": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "dryRun": {
        "type": "boolean"
      },
      "plannedChanges": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "op",
            "target"
          ],
          "properties": {
            "op": {
              "type": "string",
              "enum": [
                "create",
                "overwrite",
                "skip",
                "spawn"
              ]
            },
            "target": {
              "type": "string"
            },
            "detail": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      }
    },
    "additionalProperties": false
  },
  "errorCodes": [
    0,
    2,
    64,
    65,
    66,
    69,
    70,
    77,
    124
  ]
}
